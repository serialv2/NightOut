<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIDeviceFamily</key>
	<array>
		<integer>1</integer>
		<integer>2</integer>
	</array>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>XSAppIconAssets</key>
	<string>Assets.xcassets/appicon.appiconset</string>

	<key>NSCameraUsageDescription</key>
	<string>Spotiz utilise l'appareil photo pour scanner les QR codes de récompense et envoyer des photos ou vidéos.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Spotiz utilise la galerie pour choisir des photos et vidéos à partager.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Spotiz peut enregistrer des médias dans la galerie.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Spotiz utilise le micro lors de l'enregistrement d'une vidéo.</string>

	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Spotiz utilise le Bluetooth pour detecter les balises des bars et valider automatiquement votre presence.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>Spotiz utilise le Bluetooth pour detecter les balises des bars et valider automatiquement votre presence.</string>

	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Spotiz utilise votre position pour afficher les bars et événements proches de vous.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Spotiz utilise votre position pour afficher les bars et événements proches de vous.</string>

	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>spotiz</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>spotiz</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
