<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="NightOut.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:map="clr-namespace:NightOut.Views.Map"
    xmlns:events="clr-namespace:NightOut.Views.Events"
    xmlns:friends="clr-namespace:NightOut.Views.Friends"
    xmlns:messages="clr-namespace:NightOut.Views.Messages"
    xmlns:profile="clr-namespace:NightOut.Views.Profile"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="{DynamicResource BgDeep}">
    
    <Shell.Resources>
        <ResourceDictionary>
            <Style TargetType="Shell">
                <Setter Property="Shell.BackgroundColor"       Value="{DynamicResource BgDeep}"/>
                <Setter Property="Shell.ForegroundColor"       Value="{DynamicResource TextPrimary}"/>
                <Setter Property="Shell.TitleColor"            Value="{DynamicResource TextPrimary}"/>
                <Setter Property="Shell.TabBarBackgroundColor" Value="{DynamicResource BgDeep}"/>
                <Setter Property="Shell.TabBarForegroundColor" Value="{DynamicResource Accent}"/>
                <Setter Property="Shell.TabBarUnselectedColor" Value="{DynamicResource TextMuted}"/>
                <Setter Property="Shell.TabBarTitleColor"      Value="{DynamicResource Accent}"/>
            </Style>
        </ResourceDictionary>
    </Shell.Resources>

    <ShellContent Route="MapPage"      ContentTemplate="{DataTemplate map:MapPage}"/>
    <ShellContent Route="EventsPage"   ContentTemplate="{DataTemplate events:EphemeralEventsPage}"/>
    <ShellContent Route="FriendsPage"  ContentTemplate="{DataTemplate friends:FriendsPage}"/>
    <ShellContent Route="MessagesPage" ContentTemplate="{DataTemplate messages:MessagesPage}"/>
    <ShellContent Route="ProfilePage"  ContentTemplate="{DataTemplate profile:ProfilePage}"/>
</Shell>
