<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ══════════════════════════════════════════════ -->
    <!-- BACKGROUNDS — Sézane (crème / chaud)           -->
    <!-- ══════════════════════════════════════════════ -->
    <Color x:Key="BgDeep">#F4EFE6</Color>
    <Color x:Key="BgCard">#FAF6EF</Color>
    <Color x:Key="BgPanel">#EFE7D8</Color>
    <Color x:Key="BgElevated">#E5DCC9</Color>
    <Color x:Key="BgInput">#FFFFFF</Color>

    <!-- ══════════════════════════════════════════════ -->
    <!-- ACCENT PRINCIPAL — Terracotta                  -->
    <!-- ══════════════════════════════════════════════ -->
    <Color x:Key="Accent">#C2754C</Color>
    <Color x:Key="AccentDark">#A35C36</Color>
    <Color x:Key="AccentDim">#1AC2754C</Color>
    <Color x:Key="AccentSoft">#2EC2754C</Color>
    <Color x:Key="AccentGlow">#4DC2754C</Color>

    <!-- ══════════════════════════════════════════════ -->
    <!-- SECONDAIRE — Vert sauge                        -->
    <!-- ══════════════════════════════════════════════ -->
    <Color x:Key="Second">#6B7F5C</Color>
    <Color x:Key="SecondDim">#1F6B7F5C</Color>

    <!-- ══════════════════════════════════════════════ -->
    <!-- TEXTES                                         -->
    <!-- ══════════════════════════════════════════════ -->
    <Color x:Key="TextPrimary">#3D2817</Color>
    <Color x:Key="TextSecondary">#8A6F4A</Color>
    <Color x:Key="TextMuted">#B5A688</Color>

    <!-- ══════════════════════════════════════════════ -->
    <!-- BORDURES                                       -->
    <!-- ══════════════════════════════════════════════ -->
    <Color x:Key="Border">#E5DCC9</Color>
    <Color x:Key="BorderMid">#D4C7B5</Color>
    <Color x:Key="BorderStrong">#C2754C</Color>

    <!-- ══════════════════════════════════════════════ -->
    <!-- JAUGES (affluence bar)                         -->
    <!-- ══════════════════════════════════════════════ -->
    <Color x:Key="GaugeLow">#6B7F5C</Color>
    <Color x:Key="GaugeMid">#C9943E</Color>
    <Color x:Key="GaugeHot">#C2754C</Color>
    <Color x:Key="GaugeFire">#B5482F</Color>

    <!-- ══════════════════════════════════════════════ -->
    <!-- ÉTATS SYSTÈME                                  -->
    <!-- ══════════════════════════════════════════════ -->
    <Color x:Key="Success">#4A7A52</Color>
    <Color x:Key="Warning">#C9943E</Color>
    <Color x:Key="Error">#B5482F</Color>
    <Color x:Key="Info">#6B8CAE</Color>

    <!-- ══════════════════════════════════════════════ -->
    <!-- BRUSHES                                        -->
    <!-- ══════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="BgDeepBrush"      Color="{StaticResource BgDeep}"/>
    <SolidColorBrush x:Key="BgCardBrush"      Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="BgPanelBrush"     Color="{StaticResource BgPanel}"/>
    <SolidColorBrush x:Key="BgElevatedBrush"  Color="{StaticResource BgElevated}"/>
    <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="SecondBrush"      Color="{StaticResource Second}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>

    <!-- Conservés pour compatibilité MAUI interne -->
    <Color x:Key="Primary">#C2754C</Color>
    <Color x:Key="PrimaryDark">#A35C36</Color>
    <Color x:Key="Secondary">#6B7F5C</Color>
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Gray100">#EDE6D9</Color>
    <Color x:Key="Gray200">#DCD2BE</Color>
    <Color x:Key="Gray300">#C4B79E</Color>
    <Color x:Key="Gray400">#A6987C</Color>
    <Color x:Key="Gray500">#8A6F4A</Color>
    <Color x:Key="Gray600">#5C4A32</Color>
    <Color x:Key="Gray900">#3D2817</Color>
    <Color x:Key="Gray950">#2A1B10</Color>
    <SolidColorBrush x:Key="PrimaryBrush"   Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="WhiteBrush"     Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush"     Color="{StaticResource Black}"/>

</ResourceDictionary>
