<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NightOut.Views.Friends.FriendsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:NightOut.Views.Controls"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="#0A1018">

    <Grid RowDefinitions="*,Auto">
        <Grid Grid.Row="0" RowDefinitions="Auto,Auto,*" BackgroundColor="#0A1018">
            <Grid Grid.Row="0" Padding="16,50,16,10" ColumnDefinitions="*,Auto">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Amis" FontSize="24" FontAttributes="Bold" TextColor="#F2E8D5"/>
                    <Label Text="Invitations, demandes, groupes, sorties et crédits" FontSize="12" TextColor="#66768A"/>
                </VerticalStackLayout>
                <Frame Grid.Column="1" Padding="10,6" CornerRadius="12" HasShadow="False" BorderColor="Transparent" BackgroundColor="#1E2A38">
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="🪙" FontSize="14"/>
                        <Label Text="{Binding CreditsBalance}" TextColor="#F2E8D5" FontAttributes="Bold"/>
                    </HorizontalStackLayout>
                </Frame>
            </Grid>

            <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="12,0,12,8">
                <HorizontalStackLayout Spacing="8">
                    <Button x:Name="BtnAmis" Text="Amis" BackgroundColor="#A855F7" TextColor="#F4EEFF" CornerRadius="8" Padding="14,8" Clicked="OnAmisClicked"/>
                    <Button x:Name="BtnDemandes" Text="Demandes" BackgroundColor="Transparent" TextColor="#555B7A" CornerRadius="8" Padding="14,8" Clicked="OnDemandesClicked"/>
                    <Button x:Name="BtnRecherche" Text="Recherche" BackgroundColor="Transparent" TextColor="#555B7A" CornerRadius="8" Padding="14,8" Clicked="OnRechercheClicked"/>
                    <Button x:Name="BtnInviter" Text="Inviter" BackgroundColor="Transparent" TextColor="#555B7A" CornerRadius="8" Padding="14,8" Clicked="OnInviterClicked"/>
                    <Button x:Name="BtnGroupes" Text="{Binding GroupsTabTitle}" BackgroundColor="Transparent" TextColor="#555B7A" CornerRadius="8" Padding="14,8" Clicked="OnGroupesClicked"/>
                </HorizontalStackLayout>
            </ScrollView>

            <Grid Grid.Row="2" x:Name="PanelAmis">
                <CollectionView ItemsSource="{Binding Friends}" BackgroundColor="Transparent" Margin="16,0">
                    <CollectionView.EmptyView><Label Text="Aucun ami pour l'instant" TextColor="#3D5068" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,40"/></CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="48,*,Auto" Padding="0,8" ColumnSpacing="12">
                                <Frame Grid.Column="0" WidthRequest="44" HeightRequest="44" CornerRadius="22" Padding="0" BorderColor="Transparent" BackgroundColor="#1E2A38" IsClippedToBounds="True"><Image Source="{Binding Profile.AvatarUrl}" Aspect="AspectFill"/></Frame>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2"><Label Text="{Binding Profile.Username}" TextColor="#F2E8D5" FontSize="15" FontAttributes="Bold"/><Label Text="{Binding StatusLabel}" TextColor="#66768A" FontSize="12"/></VerticalStackLayout>
                                <Button Grid.Column="2" Text="Retirer" FontSize="12" BackgroundColor="#1E2A38" TextColor="#F2E8D5" CornerRadius="8" Padding="10,6" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveFriendCommand}" CommandParameter="{Binding .}"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <Grid Grid.Row="2" x:Name="PanelDemandes" IsVisible="False">
                <ScrollView>
                    <VerticalStackLayout Padding="16,0,16,20" Spacing="10">
                        <Label Text="Demandes reçues" TextColor="#F2E8D5" FontSize="16" FontAttributes="Bold"/>
                        <CollectionView ItemsSource="{Binding PendingRequests}" HeightRequest="220" BackgroundColor="Transparent">
                            <CollectionView.EmptyView><Label Text="Aucune demande reçue" TextColor="#3D5068" HorizontalOptions="Center" Margin="0,24"/></CollectionView.EmptyView>
                            <CollectionView.ItemTemplate><DataTemplate><Grid ColumnDefinitions="48,*,Auto,Auto" Padding="0,8" ColumnSpacing="8"><Frame Grid.Column="0" WidthRequest="44" HeightRequest="44" CornerRadius="22" Padding="0" BorderColor="Transparent" BackgroundColor="#1E2A38" IsClippedToBounds="True"><Image Source="{Binding RequesterAvatar}" Aspect="AspectFill"/></Frame><VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2"><Label Text="{Binding RequesterName}" TextColor="#F2E8D5" FontSize="15" FontAttributes="Bold"/><Label Text="Veut t’ajouter en ami" TextColor="#66768A" FontSize="12"/></VerticalStackLayout><Button Grid.Column="2" Text="✓" BackgroundColor="#A855F7" TextColor="#F4EEFF" CornerRadius="8" WidthRequest="40" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AcceptRequestCommand}" CommandParameter="{Binding .}"/><Button Grid.Column="3" Text="✕" BackgroundColor="#1E2A38" TextColor="#F2E8D5" CornerRadius="8" WidthRequest="40" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeclineRequestCommand}" CommandParameter="{Binding .}"/></Grid></DataTemplate></CollectionView.ItemTemplate>
                        </CollectionView>
                        <BoxView HeightRequest="1" Color="#1E2A38" Margin="0,4"/>
                        <Label Text="Demandes envoyées" TextColor="#F2E8D5" FontSize="16" FontAttributes="Bold"/>
                        <CollectionView ItemsSource="{Binding SentRequests}" HeightRequest="220" BackgroundColor="Transparent">
                            <CollectionView.EmptyView><Label Text="Aucune demande envoyée" TextColor="#3D5068" HorizontalOptions="Center" Margin="0,24"/></CollectionView.EmptyView>
                            <CollectionView.ItemTemplate><DataTemplate><Grid ColumnDefinitions="48,*,Auto" Padding="0,8" ColumnSpacing="8"><Frame Grid.Column="0" WidthRequest="44" HeightRequest="44" CornerRadius="22" Padding="0" BorderColor="Transparent" BackgroundColor="#1E2A38" IsClippedToBounds="True"><Image Source="{Binding AddresseeAvatar}" Aspect="AspectFill"/></Frame><VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2"><Label Text="{Binding AddresseeName}" TextColor="#F2E8D5" FontSize="15" FontAttributes="Bold"/><Label Text="{Binding StatusLabel}" TextColor="#66768A" FontSize="12"/></VerticalStackLayout><Button Grid.Column="2" Text="Annuler" FontSize="12" BackgroundColor="#1E2A38" TextColor="#F2E8D5" CornerRadius="8" Padding="10,6" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CancelSentRequestCommand}" CommandParameter="{Binding .}"/></Grid></DataTemplate></CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>

            <Grid Grid.Row="2" x:Name="PanelRecherche" IsVisible="False">
                <VerticalStackLayout Padding="16,0,16,20" Spacing="12">
                    <Entry Placeholder="Rechercher un utilisateur" PlaceholderColor="#66768A" TextColor="#F2E8D5" BackgroundColor="#1E2A38" TextChanged="OnSearchTextChanged"/>
                    <CollectionView ItemsSource="{Binding SearchResults}">
                        <CollectionView.EmptyView><Label Text="Recherche un ami par pseudo" TextColor="#3D5068" HorizontalOptions="Center" Margin="0,24"/></CollectionView.EmptyView>
                        <CollectionView.ItemTemplate><DataTemplate><Grid ColumnDefinitions="48,*,Auto" Padding="0,8" ColumnSpacing="10"><Frame WidthRequest="44" HeightRequest="44" CornerRadius="22" Padding="0" BackgroundColor="#1E2A38" BorderColor="Transparent" IsClippedToBounds="True"><Image Source="{Binding AvatarUrl}" Aspect="AspectFill"/></Frame><Label Grid.Column="1" Text="{Binding Username}" TextColor="#F2E8D5" VerticalOptions="Center" FontAttributes="Bold"/><Button Grid.Column="2" Text="Ajouter" BackgroundColor="#A855F7" TextColor="#F4EEFF" CornerRadius="8" Padding="10,6" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SendRequestCommand}" CommandParameter="{Binding .}"/></Grid></DataTemplate></CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Grid>

            <Grid Grid.Row="2" x:Name="PanelInviter" IsVisible="False">
                <ScrollView>
                    <VerticalStackLayout Padding="16,0,16,24" Spacing="14">
                        <Frame Padding="16" CornerRadius="18" HasShadow="False" BorderColor="Transparent" BackgroundColor="#111820">
                            <VerticalStackLayout Spacing="10">
                                <Label Text="Inviter un ami" TextColor="#F2E8D5" FontSize="18" FontAttributes="Bold"/>
                                <Label Text="Partage ton lien par WhatsApp, Snap, Messenger, SMS ou contacts." TextColor="#66768A" FontSize="13"/>
                                <Button Text="Créer et partager mon lien" BackgroundColor="#A855F7" TextColor="#F4EEFF" CornerRadius="10" Command="{Binding InviteFriendCommand}"/>
                            </VerticalStackLayout>
                        </Frame>
                        <Label Text="Invitations actives" TextColor="#F2E8D5" FontSize="16" FontAttributes="Bold"/>
                        <CollectionView ItemsSource="{Binding MyInvites}" HeightRequest="170"><CollectionView.EmptyView><Label Text="Aucune invitation active" TextColor="#3D5068" HorizontalOptions="Center" Margin="0,20"/></CollectionView.EmptyView><CollectionView.ItemTemplate><DataTemplate><Grid ColumnDefinitions="*,Auto" Padding="0,8"><VerticalStackLayout><Label Text="{Binding InviteCode}" TextColor="#F2E8D5" FontAttributes="Bold"/><Label Text="{Binding ShareUrl}" TextColor="#66768A" FontSize="12"/></VerticalStackLayout><Label Grid.Column="1" Text="pending" TextColor="#A855F7" VerticalOptions="Center"/></Grid></DataTemplate></CollectionView.ItemTemplate></CollectionView>
                        <Label Text="Historique crédits" TextColor="#F2E8D5" FontSize="16" FontAttributes="Bold"/>
                        <CollectionView ItemsSource="{Binding CreditHistory}" HeightRequest="220"><CollectionView.EmptyView><Label Text="Aucun crédit pour le moment" TextColor="#3D5068" HorizontalOptions="Center" Margin="0,20"/></CollectionView.EmptyView><CollectionView.ItemTemplate><DataTemplate><Grid ColumnDefinitions="*,Auto" Padding="0,8"><Label Text="{Binding ReasonLabel}" TextColor="#F2E8D5"/><Label Grid.Column="1" Text="{Binding AmountLabel}" TextColor="#A855F7" FontAttributes="Bold"/></Grid></DataTemplate></CollectionView.ItemTemplate></CollectionView>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>

            <Grid Grid.Row="2" x:Name="PanelGroupes" IsVisible="False" BackgroundColor="#05070D">
                <ScrollView>
                    <VerticalStackLayout Spacing="14" Padding="16,8,16,24">

                        <!-- MES GROUPES : la liste reste dans l'onglet Amis -->
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Mes groupes" TextColor="#F9FAFB" FontSize="22" FontAttributes="Bold"/>
                                <Label Text="Choisis un groupe pour ouvrir sa page premium en plein écran" TextColor="#8B94A7" FontSize="12"/>
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="+ Créer" BackgroundColor="#7C3AED" TextColor="White" CornerRadius="18" Padding="14,8" Command="{Binding CreateGroupCommand}"/>
                        </Grid>

                        <Frame Padding="14" CornerRadius="24" HasShadow="False" BorderColor="Transparent" BackgroundColor="#10131B">
                            <VerticalStackLayout Spacing="10">
                                <Label Text="Créer un groupe d'amis" TextColor="#F9FAFB" FontSize="16" FontAttributes="Bold"/>
                                <Grid ColumnDefinitions="*,78" ColumnSpacing="10">
                                    <Entry Placeholder="Nom du groupe" PlaceholderColor="#8B94A7" TextColor="#F9FAFB" BackgroundColor="#1A1F2B" Text="{Binding NewGroupName}"/>
                                    <Entry Grid.Column="1" Placeholder="Emoji" PlaceholderColor="#8B94A7" TextColor="#F9FAFB" BackgroundColor="#1A1F2B" Text="{Binding NewGroupEmoji}"/>
                                </Grid>
                                <Button Text="Créer le groupe" BackgroundColor="#7C3AED" TextColor="White" CornerRadius="16" HeightRequest="54" Command="{Binding CreateGroupCommand}"/>
                            </VerticalStackLayout>
                        </Frame>

                        <CollectionView ItemsSource="{Binding FriendGroups}" SelectionMode="None" BackgroundColor="Transparent" IsVisible="{Binding HasGroups}">
                            <CollectionView.EmptyView>
                                <Label Text="Aucun groupe pour l'instant" TextColor="#6B7280" HorizontalOptions="Center" Margin="0,30"/>
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame Margin="0,0,0,12" Padding="16" CornerRadius="24" HasShadow="False" BorderColor="#222839" BackgroundColor="#10131B">
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectGroupCommand}" CommandParameter="{Binding .}"/>
                                        </Frame.GestureRecognizers>
                                        <Grid ColumnDefinitions="64,*,Auto" ColumnSpacing="14">
                                            <Frame WidthRequest="58" HeightRequest="58" CornerRadius="18" Padding="0" IsClippedToBounds="True" BackgroundColor="#1A1F2B" BorderColor="Transparent">
                                                <Grid>
                                                    <Image Source="{Binding PhotoUrl}" Aspect="AspectFill" IsVisible="{Binding HasPhoto}"/>
                                                    <Label Text="{Binding Emoji}" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                </Grid>
                                            </Frame>
                                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                                <Label Text="{Binding DisplayTitle}" TextColor="#F9FAFB" FontAttributes="Bold" FontSize="17" LineBreakMode="TailTruncation"/>
                                                <Label Text="Toucher pour ouvrir en plein écran" TextColor="#8B94A7" FontSize="12"/>
                                            </VerticalStackLayout>
                                            <Border Grid.Column="2" IsVisible="{Binding HasUnread}" BackgroundColor="#EF4444" StrokeThickness="0" StrokeShape="RoundRectangle 12" HeightRequest="24" MinimumWidthRequest="24" Padding="8,0" VerticalOptions="Start">
                                                <Label Text="{Binding UnreadLabel}" FontSize="12" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Grid>

        <controls:BottomNavBar Grid.Row="1" ActiveTab="Friends"/>
    </Grid>
</ContentPage>
