<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NightOut.Views.Friends.GroupDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:NightOut.ViewModels"
    x:DataType="vm:FriendsViewModel"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="{DynamicResource BgDeep}">

    <Grid BackgroundColor="{DynamicResource BgDeep}">
        <ScrollView x:Name="GroupScrollView">
            <VerticalStackLayout IsVisible="{Binding HasSelectedGroup}" Spacing="0">

                <!-- BANNIERE + IDENTITE GROUPE -->
                <Grid HeightRequest="260">

                    <Image Source="{Binding SelectedGroup.PhotoUrl}"
                           Aspect="AspectFill"
                           Opacity="1" />

                    <BoxView BackgroundColor="#2A1B10"
                             Opacity="0.25" />

                    <Grid Padding="18,20,18,0"
                          ColumnDefinitions="Auto,*,Auto,Auto"
                          VerticalOptions="Start">

                        <Button Text="‹"
                                FontSize="28"
                                WidthRequest="48"
                                HeightRequest="48"
                                CornerRadius="24"
                                BackgroundColor="#662A1B10"
                                TextColor="White"
                                Padding="0"
                                Clicked="OnBackClicked" />

                        <Button Grid.Column="2"
                                Text="↗"
                                FontSize="22"
                                WidthRequest="48"
                                HeightRequest="48"
                                CornerRadius="24"
                                BackgroundColor="#662A1B10"
                                TextColor="White"
                                Padding="0"
                                Command="{Binding ShareSelectedGroupCommand}" />

                        <Button Grid.Column="3"
                                Text="⋯"
                                FontSize="26"
                                WidthRequest="48"
                                HeightRequest="48"
                                CornerRadius="24"
                                BackgroundColor="#662A1B10"
                                TextColor="White"
                                Padding="0"
                                Margin="8,0,0,0" />
                    </Grid>

                    <VerticalStackLayout VerticalOptions="End"
                                         Padding="24,0,24,24"
                                         Spacing="7">

                        <Label Text="{Binding SelectedGroup.DisplayTitle}"
                               TextColor="White"
                               FontSize="32"
                               FontAttributes="Bold"
                               LineBreakMode="TailTruncation"
                               MaxLines="1" />

                        <Label Text="{Binding SelectedGroupMetaLabel}"
                               TextColor="{DynamicResource TextPrimary}"
                               FontSize="15"
                               LineBreakMode="TailTruncation" />

                        <HorizontalStackLayout Spacing="12">
                            <Label Text="👥"
                                   FontSize="16" />

                            <Label Text="{Binding SelectedGroupMemberLabel}"
                                   TextColor="{DynamicResource TextPrimary}"
                                   FontSize="15" />

                            <Label Text="●"
                                   TextColor="{DynamicResource Success}"
                                   FontSize="15" />

                            <Label Text="{Binding SelectedGroupOnlineLabel}"
                                   TextColor="{DynamicResource TextPrimary}"
                                   FontSize="15" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                </Grid>

                <!-- ACTIONS PRINCIPALES -->
                <Grid Padding="16,18,16,8" ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Text="☷  Inviter des amis"
                            BackgroundColor="{DynamicResource BgCard}"
                            TextColor="{DynamicResource TextPrimary}"
                            BorderColor="{DynamicResource Border}"
                            BorderWidth="1"
                            CornerRadius="18"
                            HeightRequest="58"
                            Command="{Binding ShareSelectedGroupCommand}" />

                    <Button Grid.Column="1"
                            Text="📅  Nouvelle sortie"
                            BackgroundColor="{DynamicResource Accent}"
                            TextColor="White"
                            CornerRadius="18"
                            HeightRequest="58"
                            Clicked="OnGroupSortiesClicked" />
                </Grid>

                <!-- NAVIGATION GROUPE UNIQUE -->
                <!-- CONTENU GROUPE -->
                <Frame Margin="16,0,16,12" Padding="0" CornerRadius="22" HasShadow="False" BorderColor="{DynamicResource Border}" BackgroundColor="{DynamicResource BgCard}">
                    <VerticalStackLayout Spacing="0">
                        <Grid Padding="8,8" ColumnDefinitions="*,*,*,*,*" ColumnSpacing="0">
                            <Button x:Name="BtnGroupDiscussion" Text="Messages" FontSize="13" FontAttributes="Bold" BackgroundColor="Transparent" TextColor="{DynamicResource Accent}" Clicked="OnGroupDiscussionClicked"/>
                            <Button x:Name="BtnGroupSorties" Grid.Column="1" Text="Sorties" FontSize="13" FontAttributes="Bold" BackgroundColor="Transparent" TextColor="{DynamicResource TextSecondary}" Clicked="OnGroupSortiesClicked"/>
                            <Button x:Name="BtnGroupMedias" Grid.Column="2" Text="Médias" FontSize="13" FontAttributes="Bold" BackgroundColor="Transparent" TextColor="{DynamicResource TextSecondary}" Clicked="OnGroupMediasClicked"/>
                            <Button x:Name="BtnGroupMembres" Grid.Column="3" Text="Membres" FontSize="13" FontAttributes="Bold" BackgroundColor="Transparent" TextColor="{DynamicResource TextSecondary}" Clicked="OnGroupMembresClicked"/>
                            <Button x:Name="BtnGroupParametres" Grid.Column="4" Text="Réglages" FontSize="13" FontAttributes="Bold" BackgroundColor="Transparent" TextColor="{DynamicResource TextSecondary}" Clicked="OnGroupParametresClicked"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{DynamicResource Border}"/>

                        <!-- DISCUSSION -->
                        <VerticalStackLayout x:Name="GroupSectionDiscussion" Padding="14" Spacing="10">
                            <CollectionView ItemsSource="{Binding SelectedGroupMessages}" HeightRequest="310" BackgroundColor="Transparent">
                                <CollectionView.EmptyView>
                                    <Label Text="Aucun message. Lance la discussion 🍻" TextColor="{DynamicResource TextMuted}" HorizontalOptions="Center" Margin="0,24"/>
                                </CollectionView.EmptyView>

                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="{x:Null}">
                                        <Grid ColumnDefinitions="46,*,Auto" Padding="0,8" ColumnSpacing="10">
                                            <Frame WidthRequest="42" HeightRequest="42" CornerRadius="21" Padding="0" BackgroundColor="{DynamicResource BgElevated}" BorderColor="Transparent" IsClippedToBounds="True">
                                                <Image Source="{Binding Sender.AvatarUrl}" Aspect="AspectFill"/>
                                            </Frame>

                                            <VerticalStackLayout Grid.Column="1" Spacing="3">
                                                <HorizontalStackLayout Spacing="7">
                                                    <Label Text="{Binding SenderName}" TextColor="{DynamicResource TextPrimary}" FontAttributes="Bold"/>
                                                    <Label Text="{Binding TimeLabel}" TextColor="{DynamicResource TextSecondary}" FontSize="12"/>
                                                </HorizontalStackLayout>

                                                <Label Text="{Binding MessageText}" TextColor="{DynamicResource TextPrimary}" FontSize="14" IsVisible="{Binding HasText}"/>
                                                <Image Source="{Binding PhotoUrl}" Aspect="AspectFill" HeightRequest="190" IsVisible="{Binding HasPhoto}"/>

                                                <Button Text="🎥 Ouvrir la vidéo"
                                                        BackgroundColor="{DynamicResource BgElevated}"
                                                        TextColor="{DynamicResource TextPrimary}"
                                                        CornerRadius="12"
                                                        IsVisible="{Binding HasVideo}"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenMessageMediaCommand}"
                                                        CommandParameter="{Binding .}"/>
                                            </VerticalStackLayout>

                                            <Label Grid.Column="2" Text="💜" FontSize="18" TextColor="{DynamicResource Error}" VerticalOptions="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Entry Placeholder="Écrire au groupe..."
                                       PlaceholderColor="{DynamicResource TextSecondary}"
                                       TextColor="{DynamicResource TextPrimary}"
                                       BackgroundColor="{DynamicResource BgElevated}"
                                       Text="{Binding NewGroupMessage}"/>

                                <Button Grid.Column="1"
                                        Text="Envoyer"
                                        BackgroundColor="{DynamicResource Accent}"
                                        TextColor="White"
                                        CornerRadius="12"
                                        Command="{Binding SendGroupMessageCommand}"/>
                            </Grid>

                            <HorizontalStackLayout Spacing="8">
                                <Button Text="📷 Photo" BackgroundColor="{DynamicResource BgElevated}" TextColor="{DynamicResource TextPrimary}" CornerRadius="12" Command="{Binding SendGroupPhotoCommand}" CommandParameter="camera"/>
                                <Button Text="🖼️ Galerie" BackgroundColor="{DynamicResource BgElevated}" TextColor="{DynamicResource TextPrimary}" CornerRadius="12" Command="{Binding SendGroupPhotoCommand}" CommandParameter="gallery"/>
                                <Button Text="🎥 Vidéo" BackgroundColor="{DynamicResource BgElevated}" TextColor="{DynamicResource TextPrimary}" CornerRadius="12" Command="{Binding SendGroupVideoCommand}" CommandParameter="gallery"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <!-- SORTIES -->
                        <VerticalStackLayout x:Name="GroupSectionSorties" Padding="14" Spacing="12" IsVisible="False">
                            <Label Text="Proposer une soirée" TextColor="{DynamicResource TextPrimary}" FontSize="18" FontAttributes="Bold"/>

                            <Frame Padding="14" CornerRadius="18" HasShadow="False" BorderColor="{DynamicResource Border}" BackgroundColor="{DynamicResource BgCard}">
                                <VerticalStackLayout Spacing="10">
                                    <Entry Placeholder="Titre" PlaceholderColor="{DynamicResource TextSecondary}" TextColor="{DynamicResource TextPrimary}" BackgroundColor="{DynamicResource BgElevated}" Text="{Binding OutingTitle}"/>

                                    <Label Text="Bar de la soirée" TextColor="{DynamicResource TextPrimary}" FontAttributes="Bold"/>

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <Entry Placeholder="Rechercher un bar, une ville, une adresse..."
                                               PlaceholderColor="{DynamicResource TextSecondary}"
                                               TextColor="{DynamicResource TextPrimary}"
                                               BackgroundColor="{DynamicResource BgElevated}"
                                               Text="{Binding OutingBarSearchQuery}"
                                               ReturnCommand="{Binding SearchOutingBarsCommand}"/>
                                        <Button Grid.Column="1"
                                                Text="🔎"
                                                BackgroundColor="{DynamicResource Accent}"
                                                TextColor="White"
                                                CornerRadius="12"
                                                Command="{Binding SearchOutingBarsCommand}"/>
                                    </Grid>

                                    <Label Text="{Binding SelectedOutingBarLabel}"
                                           TextColor="{DynamicResource Accent}"
                                           FontAttributes="Bold"/>

                                    <CollectionView ItemsSource="{Binding AvailableBars}"
                                                    SelectionMode="None"
                                                    ItemSizingStrategy="MeasureFirstItem"
                                                    HeightRequest="180">
                                        <CollectionView.EmptyView>
                                            <Label Text="Recherche un bar par nom ou par ville. Les suggestions proches apparaîtront ici si le GPS trouve des bars."
                                                   TextColor="{DynamicResource TextSecondary}"
                                                   FontSize="13"
                                                   Margin="0,8"/>
                                        </CollectionView.EmptyView>
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="{x:Null}">
                                                <Frame Padding="10"
                                                       Margin="0,4"
                                                       CornerRadius="12"
                                                       HasShadow="False"
                                                       BackgroundColor="{DynamicResource BgElevated}"
                                                       BorderColor="{DynamicResource Border}">
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                        <VerticalStackLayout Spacing="2">
                                                            <Label Text="{Binding Name}"
                                                                   TextColor="{DynamicResource TextPrimary}"
                                                                   FontAttributes="Bold"/>
                                                            <Label Text="{Binding Address}"
                                                                   TextColor="{DynamicResource TextSecondary}"
                                                                   FontSize="12"
                                                                   LineBreakMode="TailTruncation"/>
                                                        </VerticalStackLayout>

                                                        <Button Grid.Column="1"
                                                                Text="Choisir"
                                                                BackgroundColor="{DynamicResource Accent}"
                                                                TextColor="White"
                                                                CornerRadius="12"
                                                                Padding="12,6"
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ChooseOutingBarCommand}"
                                                                CommandParameter="{Binding .}"/>
                                                    </Grid>
                                                </Frame>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>

                                    <HorizontalStackLayout Spacing="8">
                                        <DatePicker Date="{Binding OutingDate}" TextColor="{DynamicResource TextPrimary}" BackgroundColor="{DynamicResource BgElevated}"/>
                                        <TimePicker Time="{Binding OutingTime}" TextColor="{DynamicResource TextPrimary}" BackgroundColor="{DynamicResource BgElevated}"/>
                                    </HorizontalStackLayout>

                                    <Editor Placeholder="Message pour le groupe"
                                            PlaceholderColor="{DynamicResource TextSecondary}"
                                            TextColor="{DynamicResource TextPrimary}"
                                            BackgroundColor="{DynamicResource BgElevated}"
                                            HeightRequest="80"
                                            Text="{Binding OutingMessage}"/>

                                    <Button Text="Lancer l'invitation de soirée"
                                            BackgroundColor="{DynamicResource Accent}"
                                            TextColor="White"
                                            CornerRadius="12"
                                            Command="{Binding CreateGroupOutingCommand}"/>
                                </VerticalStackLayout>
                            </Frame>

                            <Label Text="Sorties du groupe" TextColor="{DynamicResource TextPrimary}" FontSize="18" FontAttributes="Bold"/>

                            <CollectionView ItemsSource="{Binding SelectedGroupOutings}" HeightRequest="390" SelectionMode="None" ItemSizingStrategy="MeasureFirstItem">
                                <CollectionView.EmptyView>
                                    <Label Text="Aucune sortie proposée" TextColor="{DynamicResource TextMuted}" HorizontalOptions="Center" Margin="0,24"/>
                                </CollectionView.EmptyView>

                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="{x:Null}">
                                        <Frame Padding="14" Margin="0,6" CornerRadius="18" HasShadow="False" BorderColor="{DynamicResource Border}" BackgroundColor="{DynamicResource BgCard}">
                                            <VerticalStackLayout Spacing="10">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                    <VerticalStackLayout Spacing="5">
                                                        <Label Text="{Binding Title}" TextColor="{DynamicResource TextPrimary}" FontAttributes="Bold" FontSize="16"/>
                                                        <Label Text="{Binding BarName}" TextColor="{DynamicResource Accent}"/>
                                                        <Label Text="{Binding PlannedLabel}" TextColor="{DynamicResource TextSecondary}" FontSize="12"/>
                                                        <Label Text="{Binding Message}" TextColor="{DynamicResource TextPrimary}"/>
                                                        <Label Text="{Binding StatsLabel}" TextColor="{DynamicResource TextPrimary}" FontAttributes="Bold"/>
                                                    </VerticalStackLayout>

                                                    <Button Grid.Column="1"
                                                            Text="Voir"
                                                            BackgroundColor="{DynamicResource Accent}"
                                                            TextColor="White"
                                                            CornerRadius="14"
                                                            Padding="12,6"
                                                            VerticalOptions="Center"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewOutingBarCommand}"
                                                            CommandParameter="{Binding .}"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                                    <Button Grid.Column="0"
                                                            Text="✅ J'y vais"
                                                            BackgroundColor="{DynamicResource BgElevated}"
                                                            TextColor="{DynamicResource TextPrimary}"
                                                            CornerRadius="12"
                                                            FontSize="12"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RespondYesToOutingCommand}"
                                                            CommandParameter="{Binding .}"/>

                                                    <Button Grid.Column="1"
                                                            Text="🤔 Peut-être"
                                                            BackgroundColor="{DynamicResource BgElevated}"
                                                            TextColor="{DynamicResource TextPrimary}"
                                                            CornerRadius="12"
                                                            FontSize="12"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RespondMaybeToOutingCommand}"
                                                            CommandParameter="{Binding .}"/>

                                                    <Button Grid.Column="2"
                                                            Text="❌ Non"
                                                            BackgroundColor="{DynamicResource BgElevated}"
                                                            TextColor="{DynamicResource TextPrimary}"
                                                            CornerRadius="12"
                                                            FontSize="12"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RespondNoToOutingCommand}"
                                                            CommandParameter="{Binding .}"/>
                                                </Grid>

                                                <Button Text="Partager cette sortie"
                                                        BackgroundColor="{DynamicResource BgElevated}"
                                                        TextColor="{DynamicResource TextPrimary}"
                                                        CornerRadius="12"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ShareOutingCommand}"
                                                        CommandParameter="{Binding .}"/>
                                            </VerticalStackLayout>
                                        </Frame>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>

                        <!-- MEDIAS -->
                        <VerticalStackLayout x:Name="GroupSectionMedias" Padding="14" Spacing="12" IsVisible="False">
                            <Label Text="Médias du groupe" TextColor="{DynamicResource TextPrimary}" FontSize="18" FontAttributes="Bold"/>

                            <CollectionView ItemsSource="{Binding SelectedGroupMessages}" HeightRequest="340">
                                <CollectionView.EmptyView>
                                    <Label Text="Aucun média pour l'instant" TextColor="{DynamicResource TextMuted}" HorizontalOptions="Center" Margin="0,24"/>
                                </CollectionView.EmptyView>

                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="{x:Null}">
                                        <Frame Padding="10" Margin="0,6" CornerRadius="18" BackgroundColor="{DynamicResource BgCard}" BorderColor="{DynamicResource Border}" HasShadow="False" IsVisible="{Binding HasMedia}">
                                            <VerticalStackLayout Spacing="6">
                                                <Image Source="{Binding PhotoUrl}" Aspect="AspectFill" HeightRequest="210" IsVisible="{Binding HasPhoto}"/>

                                                <Button Text="🎥 Ouvrir la vidéo"
                                                        BackgroundColor="{DynamicResource BgElevated}"
                                                        TextColor="{DynamicResource TextPrimary}"
                                                        CornerRadius="12"
                                                        IsVisible="{Binding HasVideo}"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenMessageMediaCommand}"
                                                        CommandParameter="{Binding .}"/>

                                                <Label Text="{Binding SenderName}" TextColor="{DynamicResource TextPrimary}" FontAttributes="Bold"/>
                                                <Label Text="{Binding TimeLabel}" TextColor="{DynamicResource TextSecondary}" FontSize="12"/>
                                            </VerticalStackLayout>
                                        </Frame>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <HorizontalStackLayout Spacing="8">
                                <Button Text="📷 Appareil photo" BackgroundColor="{DynamicResource Accent}" TextColor="White" CornerRadius="12" Command="{Binding SendGroupPhotoCommand}" CommandParameter="camera"/>
                                <Button Text="🖼️ Galerie" BackgroundColor="{DynamicResource BgElevated}" TextColor="{DynamicResource TextPrimary}" CornerRadius="12" Command="{Binding SendGroupPhotoCommand}" CommandParameter="gallery"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <!-- MEMBRES -->
                        <VerticalStackLayout x:Name="GroupSectionMembres" Padding="14" Spacing="12" IsVisible="False">
                            <Label Text="Membres du groupe" TextColor="{DynamicResource TextPrimary}" FontSize="18" FontAttributes="Bold"/>

                            <CollectionView ItemsSource="{Binding SelectedGroupMembers}" HeightRequest="240" ItemSizingStrategy="MeasureFirstItem">
                                <CollectionView.EmptyView>
                                    <Label Text="Aucun membre affiché" TextColor="{DynamicResource TextMuted}" HorizontalOptions="Center" Margin="0,24"/>
                                </CollectionView.EmptyView>

                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="{x:Null}">
                                        <Grid ColumnDefinitions="46,*,Auto" Padding="0,7" ColumnSpacing="10">
                                            <Frame WidthRequest="42" HeightRequest="42" CornerRadius="21" Padding="0" BackgroundColor="{DynamicResource BgElevated}" BorderColor="Transparent" IsClippedToBounds="True">
                                                <Image Source="{Binding AvatarUrl}" Aspect="AspectFill"/>
                                            </Frame>

                                            <VerticalStackLayout Grid.Column="1">
                                                <Label Text="{Binding DisplayName}" TextColor="{DynamicResource TextPrimary}" FontAttributes="Bold"/>
                                                <Label Text="{Binding RoleLabel}" TextColor="{DynamicResource TextSecondary}" FontSize="12"/>
                                            </VerticalStackLayout>

                                            <Button Grid.Column="2"
                                                    Text="Retirer"
                                                    FontSize="12"
                                                    BackgroundColor="{DynamicResource BgElevated}"
                                                    TextColor="{DynamicResource TextPrimary}"
                                                    CornerRadius="12"
                                                    IsVisible="{Binding CanRemove}"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveMemberFromSelectedGroupCommand}"
                                                    CommandParameter="{Binding .}"/>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <Label Text="Ajouter des amis" TextColor="{DynamicResource TextPrimary}" FontSize="16" FontAttributes="Bold" IsVisible="{Binding CanManageSelectedGroup}"/>

                            <CollectionView ItemsSource="{Binding GroupCandidateFriends}" HeightRequest="180" IsVisible="{Binding CanManageSelectedGroup}" ItemSizingStrategy="MeasureFirstItem">
                                <CollectionView.EmptyView>
                                    <Label Text="Aucun ami à ajouter" TextColor="{DynamicResource TextMuted}" HorizontalOptions="Center" Margin="0,24"/>
                                </CollectionView.EmptyView>

                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="{x:Null}">
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,8">
                                            <Label Text="{Binding Profile.Username}" TextColor="{DynamicResource TextPrimary}" VerticalOptions="Center"/>

                                            <Button Grid.Column="1"
                                                    Text="Ajouter"
                     
                                                    FontSize="12"
                                                    BackgroundColor="{DynamicResource BgElevated}"
                                                    TextColor="{DynamicResource TextPrimary}"
                                                    CornerRadius="12"
                                                    Padding="10,6"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AddFriendToSelectedGroupCommand}"
                                                    CommandParameter="{Binding .}"/>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>

                        <!-- PARAMETRES -->
                        <VerticalStackLayout x:Name="GroupSectionParametres" Padding="14" Spacing="12" IsVisible="False">
                            <Label Text="Paramètres du groupe" TextColor="{DynamicResource TextPrimary}" FontSize="18" FontAttributes="Bold"/>

                            <Button Text="Changer la photo / bannière" BackgroundColor="{DynamicResource BgElevated}" TextColor="{DynamicResource TextPrimary}" CornerRadius="12" Command="{Binding SetSelectedGroupPhotoCommand}"/>
                            <Button Text="Partager le groupe" BackgroundColor="{DynamicResource BgElevated}" TextColor="{DynamicResource TextPrimary}" CornerRadius="12" Command="{Binding ShareSelectedGroupCommand}"/>
                            <Button Text="Rafraîchir" BackgroundColor="{DynamicResource BgElevated}" TextColor="{DynamicResource TextPrimary}" CornerRadius="12" Command="{Binding LoadSelectedGroupDetailsCommand}"/>
                            <Button Text="Supprimer le groupe" BackgroundColor="{DynamicResource Error}" TextColor="{DynamicResource TextPrimary}" CornerRadius="12" IsVisible="{Binding IsSelectedGroupOwner}" Command="{Binding DeleteSelectedGroupCommand}"/>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Frame>

                <!-- PROCHAINE SORTIE EN APERCU -->
                <Frame Margin="16,0,16,24" Padding="16" CornerRadius="22" HasShadow="False" BorderColor="{DynamicResource Border}" BackgroundColor="{DynamicResource BgCard}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="📅 Prochaines sorties" TextColor="{DynamicResource TextPrimary}" FontSize="18" FontAttributes="Bold"/>
                            <Button Grid.Column="1"
                                    Text="Voir tout"
                                    BackgroundColor="Transparent"
                                    TextColor="{DynamicResource Accent}"
                                    FontAttributes="Bold"
                                    Padding="0"
                                    Clicked="OnShowAllOutingsClicked"/>
                        </Grid>

                        <Frame Padding="12" CornerRadius="18" HasShadow="False" BorderColor="{DynamicResource Border}" BackgroundColor="{DynamicResource BgCard}">
                            <Grid ColumnDefinitions="112,*" ColumnSpacing="14">
                                <Frame WidthRequest="112" HeightRequest="90" CornerRadius="16" Padding="0" IsClippedToBounds="True" BackgroundColor="{DynamicResource BgElevated}" BorderColor="Transparent">
                                    <Label Text="🍸" FontSize="42" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Frame>

                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="{Binding SelectedGroupNextOutingDate}" TextColor="{DynamicResource Accent}" FontAttributes="Bold"/>
                                    <Label Text="{Binding SelectedGroupNextOutingTitle}" TextColor="{DynamicResource TextPrimary}" FontSize="20" FontAttributes="Bold"/>
                                    <Label Text="{Binding SelectedGroupNextOutingBar}" TextColor="{DynamicResource TextPrimary}"/>
                                    <Label Text="{Binding SelectedGroupNextOutingStats}" TextColor="{DynamicResource TextPrimary}" FontAttributes="Bold"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>