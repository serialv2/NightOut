<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NightOut.Views.Events.OfficialEventDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#0A1018">

    <Grid RowDefinitions="Auto,*">

        <Grid Padding="16,16,16,10" ColumnDefinitions="Auto,*">
            <Button Text="‹"
                    WidthRequest="44"
                    HeightRequest="44"
                    CornerRadius="22"
                    BackgroundColor="#182536"
                    TextColor="#F2E8D5"
                    FontSize="26"
                    Command="{Binding BackCommand}" />

            <Label Grid.Column="1"
                   Text="Détail événement"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#F2E8D5"
                   VerticalOptions="Center"
                   Margin="12,0,0,0" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,0,20,30" Spacing="18">

                <Border Stroke="#23344A"
                        StrokeThickness="1"
                        BackgroundColor="#101A27"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>

                    <Grid RowDefinitions="260,Auto">
                        <Image Grid.Row="0"
                               Source="{Binding Event.FlyerUrl}"
                               Aspect="AspectFill"
                               BackgroundColor="#172234" />

                        <VerticalStackLayout Grid.Row="1" Padding="18" Spacing="10">
                            <Label Text="{Binding Event.Title}"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="#F2E8D5" />

                            <Label Text="{Binding Event.DateLabel}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="#FFB627" />

                            <Label Text="{Binding Event.BarDisplay}"
                                   FontSize="16"
                                   TextColor="#F2E8D5" />

                            <Label Text="{Binding Event.BarAddress}"
                                   FontSize="13"
                                   TextColor="#7E8CA0" />

                            <Label Text="{Binding Event.Description}"
                                   FontSize="14"
                                   TextColor="#D7DCE5"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border Stroke="#23344A"
                        StrokeThickness="1"
                        BackgroundColor="#101A27"
                        Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="12">
                        <Label Text="Ta réponse"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#F2E8D5" />

                        <Label Text="{Binding ParticipationLabel}"
                               FontSize="13"
                               TextColor="#7E8CA0" />

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <Button Text="J’y vais"
                                    BackgroundColor="{Binding GoingButtonBackgroundColor}"
                                    TextColor="{Binding GoingButtonTextColor}"
                                    CornerRadius="18"
                                    Command="{Binding SetParticipationCommand}"
                                    CommandParameter="going" />

                            <Button Grid.Column="1"
                                    Text="Peut-être"
                                    BackgroundColor="{Binding MaybeButtonBackgroundColor}"
                                    TextColor="{Binding MaybeButtonTextColor}"
                                    CornerRadius="18"
                                    Command="{Binding SetParticipationCommand}"
                                    CommandParameter="maybe" />

                            <Button Grid.Column="2"
                                    Text="Non"
                                    BackgroundColor="{Binding NotGoingButtonBackgroundColor}"
                                    TextColor="{Binding NotGoingButtonTextColor}"
                                    CornerRadius="18"
                                    Command="{Binding SetParticipationCommand}"
                                    CommandParameter="not_going" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Label Text="{Binding Event.GoingCount, StringFormat='✅ {0} participants'}"
                                   FontSize="12"
                                   TextColor="#7E8CA0" />

                            <Label Grid.Column="1"
                                   Text="{Binding Event.MaybeCount, StringFormat='🤔 {0} peut-être'}"
                                   FontSize="12"
                                   TextColor="#7E8CA0" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Label Text="{Binding Event.CheckedInCount, StringFormat='📍 {0} confirmés sur place'}"
                                   FontSize="12"
                                   TextColor="#1D8F5A" />
                        </Grid>

                        <BoxView HeightRequest="1"
                                 Color="#23344A"
                                 Margin="0,4" />

                        <Label Text="{Binding CheckInLabel}"
                               FontSize="13"
                               TextColor="#D7DCE5"
                               LineBreakMode="WordWrap" />

                        <Label Text="{Binding LastCheckInMessage}"
                               FontSize="12"
                               TextColor="#7E8CA0"
                               LineBreakMode="WordWrap" />

                        <Button Text="{Binding CheckInButtonText}"
                                HeightRequest="48"
                                CornerRadius="24"
                                BackgroundColor="{Binding CheckInButtonBackgroundColor}"
                                TextColor="{Binding CheckInButtonTextColor}"
                                FontAttributes="Bold"
                                Command="{Binding CheckInCommand}" />

                        <Label Text="Le score de fiabilité augmente seulement quand la présence est confirmée sur place par GPS."
                               FontSize="12"
                               TextColor="#7E8CA0"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <Border Stroke="#23344A"
                        StrokeThickness="1"
                        BackgroundColor="#101A27"
                        Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="12">
                        <Label Text="Partager avec un groupe"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#F2E8D5" />

                        <Label Text="Crée une sortie dans un de tes groupes d'amis à partir de cet événement."
                               FontSize="13"
                               TextColor="#7E8CA0" />

                        <Picker Title="Choisir un groupe"
                                ItemsSource="{Binding Groups}"
                                SelectedItem="{Binding SelectedGroup}"
                                ItemDisplayBinding="{Binding DisplayTitle}"
                                TextColor="#F2E8D5"
                                TitleColor="#7E8CA0"
                                BackgroundColor="#182536" />

                        <Button Text="Partager dans ce groupe"
                                HeightRequest="48"
                                CornerRadius="24"
                                BackgroundColor="#FFB627"
                                TextColor="#0A1018"
                                FontAttributes="Bold"
                                IsEnabled="{Binding HasGroups}"
                                Command="{Binding ShareToGroupCommand}" />
                    </VerticalStackLayout>
                </Border>

                <Button Text="{Binding FollowButtonText}"
                        HeightRequest="48"
                        CornerRadius="24"
                        BackgroundColor="#182536"
                        TextColor="#F2E8D5"
                        FontAttributes="Bold"
                        Command="{Binding ToggleFollowBarCommand}" />

                <Button Text="Voir la fiche du bar"
                        HeightRequest="48"
                        CornerRadius="24"
                        BackgroundColor="#23344A"
                        TextColor="#F2E8D5"
                        Command="{Binding OpenBarCommand}" />

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
