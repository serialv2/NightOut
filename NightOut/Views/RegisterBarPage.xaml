<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="NightOut.Views.Bar.RegisterBarPage"
             BackgroundColor="{DynamicResource BgDeep}">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        <toolkit:IsStringNotNullOrEmptyConverter x:Key="IsStringNotNullOrEmptyConverter" />

        <Style TargetType="Entry">
            <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
            <Setter Property="PlaceholderColor" Value="{DynamicResource TextSecondary}" />
            <Setter Property="BackgroundColor" Value="{DynamicResource BgPanel}" />
            <Setter Property="HeightRequest" Value="46" />
        </Style>
        <Style TargetType="Editor">
            <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
            <Setter Property="PlaceholderColor" Value="{DynamicResource TextSecondary}" />
            <Setter Property="BackgroundColor" Value="{DynamicResource BgPanel}" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Barre du haut -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="12,14" BackgroundColor="{DynamicResource BgCard}">
            <Button Grid.Column="0" Text="✕" FontSize="18"
                    BackgroundColor="Transparent" TextColor="{DynamicResource TextSecondary}"
                    Command="{Binding CancelCommand}" />
            <Label Grid.Column="1" Text="{Binding Title}" FontSize="18" FontAttributes="Bold"
                   VerticalOptions="Center" Margin="6,0,0,0" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="14">

                <Label Text="Nom de l'établissement *" TextColor="{DynamicResource TextSecondary}" />
                <Entry Text="{Binding Name}" Placeholder="Ex: Le Macumba" />

                <Label Text="Ville *" TextColor="{DynamicResource TextSecondary}" />
                <Picker Title="Choisir une ville"
                        TitleColor="{DynamicResource TextSecondary}"
                        TextColor="{DynamicResource TextPrimary}"
                        BackgroundColor="{DynamicResource BgPanel}"
                        ItemsSource="{Binding Cities}"
                        ItemDisplayBinding="{Binding Name}"
                        SelectedItem="{Binding SelectedCity}" />

                <!-- Adresse + géocodage -->
                <Label Text="Adresse *" TextColor="{DynamicResource TextSecondary}" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Entry Grid.Column="0" Text="{Binding Address}" Placeholder="Rue, ville..." />
                    <Button Grid.Column="1" Text="Rechercher"
                            BackgroundColor="{DynamicResource Second}" TextColor="White"
                            Command="{Binding SearchAddressCommand}" />
                </Grid>

                <!-- Suggestions Mapbox -->
                <CollectionView x:Name="SuggestionsList"
                                ItemsSource="{Binding AddressSuggestions}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="{DynamicResource BgPanel}"
                                    StrokeThickness="0" Margin="0,3"
                                    Padding="12" StrokeShape="RoundRectangle 10">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding BindingContext.SelectSuggestionCommand, Source={x:Reference SuggestionsList}}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding PlaceName}" TextColor="{DynamicResource TextPrimary}" FontSize="14" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Position confirmée -->
                <Border IsVisible="{Binding HasCoordinates}"
                        BackgroundColor="{DynamicResource BgCard}" Padding="12"
                        StrokeThickness="1" Stroke="{DynamicResource Success}"
                        StrokeShape="RoundRectangle 10">
                    <Label TextColor="{DynamicResource Success}" FontSize="13">
                        <Label.Text>
                            <MultiBinding StringFormat="📍 {0}">
                                <Binding Path="ResolvedAddressLabel" />
                            </MultiBinding>
                        </Label.Text>
                    </Label>
                </Border>

                <!-- Catégories -->
                <Label Text="Catégories" TextColor="{DynamicResource TextSecondary}" Margin="0,4,0,0" />
                <CollectionView ItemsSource="{Binding Categories}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto,*" Padding="0,4">
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                          Color="{DynamicResource Accent}" />
                                <Label Grid.Column="1" Text="{Binding Display}"
                                       VerticalOptions="Center" FontSize="15" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Optionnels -->
                <Label Text="Description" TextColor="{DynamicResource TextSecondary}" />
                <Editor Text="{Binding Description}" AutoSize="TextChanges" HeightRequest="90"
                        Placeholder="Ambiance, concept..." />

                <Label Text="Téléphone" TextColor="{DynamicResource TextSecondary}" />
                <Entry Text="{Binding Phone}" Keyboard="Telephone" Placeholder="03 ..." />

                <Label Text="Site web" TextColor="{DynamicResource TextSecondary}" />
                <Entry Text="{Binding Website}" Keyboard="Url" Placeholder="https://" />

                <Label Text="Instagram" TextColor="{DynamicResource TextSecondary}" />
                <Entry Text="{Binding Instagram}" Placeholder="@..." />

                <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                    <Label Grid.Column="0" Text="Promo en cours" VerticalOptions="Center" />
                    <Switch Grid.Column="1" IsToggled="{Binding HasPromo}"
                            OnColor="{DynamicResource Second}" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                    <Label Grid.Column="0" Text="Actif (visible sur la carte)" VerticalOptions="Center" />
                    <Switch Grid.Column="1" IsToggled="{Binding IsActive}"
                            OnColor="{DynamicResource Success}" />
                </Grid>

                <!-- Statut -->
                <Label Text="{Binding StatusMessage}" TextColor="{DynamicResource Accent}"
                       IsVisible="{Binding StatusMessage, Converter={StaticResource IsStringNotNullOrEmptyConverter}}"
                       FontSize="13" />

                <!-- Enregistrer -->
                <Button Text="Enregistrer l'établissement"
                        BackgroundColor="{DynamicResource Accent}" TextColor="{DynamicResource BgDeep}"
                        FontAttributes="Bold" HeightRequest="50" Margin="0,8,0,0"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   Color="{DynamicResource Accent}" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
