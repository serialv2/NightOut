<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NightOut.Views.Auth.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:NightOut.ViewModels"
    x:DataType="vm:RegisterViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{DynamicResource BgDeep}">

    <ScrollView>
        <VerticalStackLayout Padding="28,60,28,40" Spacing="0">

            <!-- Retour -->
            <Label
                Text="&lt; Retour"
                FontFamily="DMSans-Regular"
                FontSize="14"
                TextColor="{DynamicResource TextSecondary}"
                Margin="0,0,0,32">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToLoginCommand}"/>
                </Label.GestureRecognizers>
            </Label>

            <!-- Logo -->
            <Label
                Text="Spotiz"
                FontFamily="PlayfairDisplay-BoldItalic"
                FontSize="36"
                TextColor="{DynamicResource Accent}"
                HorizontalOptions="Center"
                Margin="0,0,0,8"/>

            <Label
                Text="Cree ton compte"
                FontFamily="DMSans-SemiBold"
                FontSize="22"
                TextColor="{DynamicResource TextPrimary}"
                HorizontalOptions="Center"
                Margin="0,0,0,6"/>

            <Label
                Text="Rejoins la communaute Spotiz"
                FontFamily="DMSans-Regular"
                FontSize="14"
                TextColor="{DynamicResource TextSecondary}"
                HorizontalOptions="Center"
                Margin="0,0,0,36"/>

            <!-- Type de compte -->
            <Label Text="Type de compte" FontFamily="DMSans-Medium" FontSize="12" TextColor="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>

            <Border BackgroundColor="{DynamicResource BgCard}" Stroke="{DynamicResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 18" Padding="14" Margin="0,0,0,18">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <CheckBox Grid.Column="0" IsChecked="{Binding IsUserAccount}" Color="{DynamicResource Accent}"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="1">
                            <Label Text="Utilisateur" FontFamily="DMSans-SemiBold" FontSize="14" TextColor="{DynamicResource TextPrimary}"/>
                            <Label Text="Sorties, amis, groupes et carte Spotiz." FontFamily="DMSans-Regular" FontSize="11" TextColor="{DynamicResource TextSecondary}"/>
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <CheckBox Grid.Column="0" IsChecked="{Binding IsEstablishmentAccount}" Color="{DynamicResource Accent}"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="1">
                            <Label Text="Etablissement / bar" FontFamily="DMSans-SemiBold" FontSize="14" TextColor="{DynamicResource TextPrimary}"/>
                            <Label Text="Compte pro soumis a validation Spotiz." FontFamily="DMSans-Regular" FontSize="11" TextColor="{DynamicResource TextSecondary}"/>
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <CheckBox Grid.Column="0" IsChecked="{Binding IsOrganizerAccount}" Color="{DynamicResource Accent}"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="1">
                            <Label Text="Organisateur d'evenements" FontFamily="DMSans-SemiBold" FontSize="14" TextColor="{DynamicResource TextPrimary}"/>
                            <Label Text="DJ, association, BDE, festival, comite des fetes..." FontFamily="DMSans-Regular" FontSize="11" TextColor="{DynamicResource TextSecondary}"/>
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="Les fonctions pro seront bloquees jusqu'a validation administrative." FontFamily="DMSans-Regular" FontSize="11" TextColor="{DynamicResource Accent}" Margin="0,4,0,0"/>
                </VerticalStackLayout>
            </Border>

            <!-- Pseudo -->
            <Label Text="Pseudo" FontFamily="DMSans-Medium" FontSize="12" TextColor="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
            <Border Style="{StaticResource InputField}" Margin="0,0,0,6">
                <Entry Text="{Binding Username}" Placeholder="ton_pseudo" ReturnType="Next"/>
            </Border>
            <Label Text="Visible par tes amis sur la carte" FontFamily="DMSans-Regular" FontSize="11" TextColor="{DynamicResource TextMuted}" Margin="0,0,0,16"/>

            <!-- Email -->
            <Label Text="Adresse e-mail" FontFamily="DMSans-Medium" FontSize="12" TextColor="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
            <Border Style="{StaticResource InputField}" Margin="0,0,0,16">
                <Entry Text="{Binding Email}" Placeholder="ton@email.com" Keyboard="Email" ReturnType="Next"/>
            </Border>

            <!-- Mot de passe -->
            <Label Text="Mot de passe" FontFamily="DMSans-Medium" FontSize="12" TextColor="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
            <Border Style="{StaticResource InputField}" Margin="0,0,0,16">
                <Grid ColumnDefinitions="*,Auto">
                    <Entry
                        Grid.Column="0"
                        Text="{Binding Password}"
                        Placeholder="8 caracteres minimum"
                        IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InvertedBoolConverter}}"
                        ReturnType="Next"/>
                    <Label
                        Grid.Column="1"
                        Text="Voir"
                        FontSize="18"
                        TextColor="{DynamicResource TextSecondary}"
                        VerticalOptions="Center"
                        Padding="8,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Border>

            <!-- Confirmation -->
            <Label Text="Confirmer le mot de passe" FontFamily="DMSans-Medium" FontSize="12" TextColor="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
            <Border Style="{StaticResource InputField}" Margin="0,0,0,24">
                <Entry
                    Text="{Binding PasswordConfirm}"
                    Placeholder="mot de passe"
                    IsPassword="True"
                    ReturnType="Done"
                    ReturnCommand="{Binding RegisterCommand}"/>
            </Border>

            <!-- CGU -->
            <HorizontalStackLayout Spacing="10" Margin="0,0,0,24">
                <CheckBox IsChecked="{Binding AcceptTerms}" Color="{DynamicResource Accent}"/>
                <Label VerticalOptions="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="J'accepte les " FontFamily="DMSans-Regular" FontSize="12" TextColor="{DynamicResource TextSecondary}"/>
                            <Span Text="conditions d'utilisation" FontFamily="DMSans-Medium" FontSize="12" TextColor="{DynamicResource Accent}"/>
                            <Span Text=" et la " FontFamily="DMSans-Regular" FontSize="12" TextColor="{DynamicResource TextSecondary}"/>
                            <Span Text="politique de confidentialite" FontFamily="DMSans-Medium" FontSize="12" TextColor="{DynamicResource Accent}"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </HorizontalStackLayout>

            <!-- Confirmation email -->
            <Label
                Text="{Binding StatusMessage}"
                FontFamily="DMSans-Regular"
                FontSize="12"
                TextColor="{DynamicResource Success}"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                IsVisible="{Binding HasStatus}"
                Margin="0,0,0,16"/>

            <!-- Erreur -->
            <Label
                Text="{Binding ErrorMessage}"
                FontFamily="DMSans-Regular"
                FontSize="12"
                TextColor="{DynamicResource Error}"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                IsVisible="{Binding HasError}"
                Margin="0,0,0,16"/>

            <!-- Bouton créer -->
            <Border Style="{StaticResource BtnPrimary}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{DynamicResource Accent}" Offset="0"/>
                        <GradientStop Color="{DynamicResource Second}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding RegisterCommand}"/>
                </Border.GestureRecognizers>
                <Grid>
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{DynamicResource BgDeep}" HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Label Text="Creer mon compte" FontFamily="DMSans-Bold" FontSize="15" TextColor="{DynamicResource BgDeep}" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="{Binding IsNotBusy}"/>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,Auto,*" Margin="0,18,0,14">
                <BoxView Grid.Column="0" HeightRequest="1" BackgroundColor="{DynamicResource Border}" VerticalOptions="Center"/>
                <Label Grid.Column="1" Text="ou" FontSize="12" TextColor="{DynamicResource TextSecondary}" Margin="12,0"/>
                <BoxView Grid.Column="2" HeightRequest="1" BackgroundColor="{DynamicResource Border}" VerticalOptions="Center"/>
            </Grid>

            <Border
                HeightRequest="52"
                Stroke="{DynamicResource Border}"
                StrokeThickness="1"
                BackgroundColor="{DynamicResource BgCard}"
                StrokeShape="RoundRectangle 18">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding RegisterWithGoogleCommand}"/>
                </Border.GestureRecognizers>

                <Grid ColumnDefinitions="Auto,*" Padding="16,0">
                    <Label
                        Grid.Column="0"
                        Text="G"
                        FontFamily="DMSans-Bold"
                        FontSize="20"
                        TextColor="{DynamicResource TextPrimary}"
                        VerticalOptions="Center"/>

                    <Label
                        Grid.Column="1"
                        Text="S'inscrire avec Google"
                        FontFamily="DMSans-SemiBold"
                        FontSize="15"
                        TextColor="{DynamicResource TextPrimary}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
