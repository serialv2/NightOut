<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NightOut.Views.Auth.ForgotPasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:NightOut.ViewModels"
    x:DataType="vm:ForgotPasswordViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{DynamicResource BgDeep}">

    <VerticalStackLayout Padding="28,60,28,40" Spacing="0">

        <!-- Retour -->
        <Label Text="← Retour" FontFamily="DMSans-Regular" FontSize="14" TextColor="{DynamicResource TextSecondary}" Margin="0,0,0,40">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
            </Label.GestureRecognizers>
        </Label>

        <Label Text="🔑" FontSize="48" HorizontalOptions="Center" Margin="0,0,0,16"/>

        <Label
            Text="Mot de passe oublié ?"
            FontFamily="DMSans-SemiBold"
            FontSize="22"
            TextColor="{DynamicResource TextPrimary}"
            HorizontalOptions="Center"
            Margin="0,0,0,8"/>

        <Label
            Text="Entre ton e-mail, on t'envoie un lien de réinitialisation"
            FontFamily="DMSans-Regular"
            FontSize="14"
            TextColor="{DynamicResource TextSecondary}"
            HorizontalOptions="Center"
            HorizontalTextAlignment="Center"
            Margin="0,0,0,36"/>

        <!-- Email -->
        <Label Text="Adresse e-mail" FontFamily="DMSans-Medium" FontSize="12" TextColor="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
        <Border Style="{StaticResource InputField}" Margin="0,0,0,24">
            <Entry Text="{Binding Email}" Placeholder="ton@email.com" Keyboard="Email"/>
        </Border>

        <!-- Succès -->
        <Border
            BackgroundColor="#14659B4B"
            Stroke="#40659B4B"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 12"
            Padding="14,12"
            Margin="0,0,0,24"
            IsVisible="{Binding IsEmailSent}">
            <Label
                Text="✓ E-mail envoyé ! Vérifie ta boîte mail."
                FontFamily="DMSans-Medium"
                FontSize="13"
                TextColor="{DynamicResource Success}"
                HorizontalOptions="Center"/>
        </Border>

        <!-- Bouton -->
        <Border Style="{StaticResource BtnPrimary}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{DynamicResource Accent}" Offset="0"/>
                    <GradientStop Color="{DynamicResource Second}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding SendResetCommand}"/>
            </Border.GestureRecognizers>
            <Grid>
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{DynamicResource BgDeep}" HorizontalOptions="Center" VerticalOptions="Center"/>
                <Label Text="Envoyer le lien" FontFamily="DMSans-Bold" FontSize="15" TextColor="{DynamicResource BgDeep}" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="{Binding IsNotBusy}"/>
            </Grid>
        </Border>

    </VerticalStackLayout>

</ContentPage>
