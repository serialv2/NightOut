<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NightOut.Views.Auth.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:NightOut.ViewModels"
    x:DataType="vm:LoginViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{DynamicResource BgDeep}">

    <ScrollView>
        <Grid RowDefinitions="Auto,*" MinimumHeightRequest="760">

            <Grid
                Grid.Row="0"
                HeightRequest="260"
                Padding="28,56,28,24">

                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{DynamicResource BgElevated}" Offset="0"/>
                        <GradientStop Color="{DynamicResource BgDeep}" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>

                <VerticalStackLayout
                    Spacing="10"
                    VerticalOptions="Center">

                    <Label
                        Text="Spotiz"
                        FontFamily="PlayfairDisplay-BoldItalic"
                        FontSize="48"
                        TextColor="{DynamicResource Accent}"
                        HorizontalOptions="Center"/>

                    <Label
                        Text="Tes amis. Tes bars. Tes soirées."
                        FontFamily="DMSans-SemiBold"
                        FontSize="17"
                        TextColor="{DynamicResource TextPrimary}"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"/>

                    <Label
                        Text="{Binding WelcomeText}"
                        FontFamily="DMSans-Regular"
                        FontSize="13"
                        TextColor="{DynamicResource TextSecondary}"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        Margin="0,4,0,0"/>

                </VerticalStackLayout>
            </Grid>

            <Border
                Grid.Row="1"
                Margin="20,-22,20,24"
                Padding="22"
                StrokeThickness="1"
                Stroke="{DynamicResource Border}"
                BackgroundColor="{DynamicResource BgElevated}"
                StrokeShape="RoundRectangle 28">

                <VerticalStackLayout Spacing="14">

                    <Label
                        Text="Connexion"
                        FontFamily="DMSans-Bold"
                        FontSize="24"
                        TextColor="{DynamicResource TextPrimary}"/>

                    <Label
                        Text="Entre tes identifiants pour continuer."
                        FontFamily="DMSans-Regular"
                        FontSize="13"
                        TextColor="{DynamicResource TextSecondary}"
                        Margin="0,0,0,10"/>

                    <Label
                        Text="Adresse e-mail"
                        FontFamily="DMSans-Medium"
                        FontSize="12"
                        TextColor="{DynamicResource TextSecondary}"/>

                    <Border
                        Style="{StaticResource InputField}">
                        <Entry
                            Text="{Binding Email}"
                            Placeholder="ton@email.com"
                            Keyboard="Email"
                            ReturnType="Next"
                            AutomationId="EmailEntry"/>
                    </Border>

                    <Label
                        Text="Mot de passe"
                        FontFamily="DMSans-Medium"
                        FontSize="12"
                        TextColor="{DynamicResource TextSecondary}"
                        Margin="0,4,0,0"/>

                    <Border
                        Style="{StaticResource InputField}">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry
                                Grid.Column="0"
                                Text="{Binding Password}"
                                Placeholder="••••••••"
                                IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InvertedBoolConverter}}"
                                ReturnType="Done"
                                ReturnCommand="{Binding LoginCommand}"
                                AutomationId="PasswordEntry"/>

                            <Label
                                Grid.Column="1"
                                Text="👁"
                                FontSize="18"
                                TextColor="{DynamicResource TextSecondary}"
                                VerticalOptions="Center"
                                Padding="10,0">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Border>

                    <Label
                        Text="Mot de passe oublié ?"
                        FontFamily="DMSans-Regular"
                        FontSize="12"
                        TextColor="{DynamicResource Accent}"
                        HorizontalOptions="End">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToForgotPasswordCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>

                    <Label
                        Text="{Binding ErrorMessage}"
                        FontFamily="DMSans-Regular"
                        FontSize="12"
                        TextColor="{DynamicResource Error}"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        IsVisible="{Binding HasError}"
                        Margin="0,4,0,0"/>

                    <Border
                        Style="{StaticResource BtnPrimary}"
                        Margin="0,8,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{DynamicResource Accent}" Offset="0"/>
                                <GradientStop Color="{DynamicResource Second}" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LoginCommand}"/>
                        </Border.GestureRecognizers>

                        <Grid>
                            <ActivityIndicator
                                IsRunning="{Binding IsBusy}"
                                IsVisible="{Binding IsBusy}"
                                Color="{DynamicResource BgDeep}"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>

                            <Label
                                Text="Se connecter"
                                FontFamily="DMSans-Bold"
                                FontSize="15"
                                TextColor="{DynamicResource BgDeep}"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                IsVisible="{Binding IsNotBusy}"/>
                        </Grid>
                    </Border>

                    <Grid ColumnDefinitions="*,Auto,*" Margin="0,10,0,2">
                        <BoxView Grid.Column="0" HeightRequest="1" BackgroundColor="{DynamicResource Border}" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="ou" FontSize="12" TextColor="{DynamicResource TextSecondary}" Margin="12,0"/>
                        <BoxView Grid.Column="2" HeightRequest="1" BackgroundColor="{DynamicResource Border}" VerticalOptions="Center"/>
                    </Grid>

                    <Border
                        HeightRequest="52"
                        Stroke="{DynamicResource Border}"
                        StrokeThickness="1"
                        BackgroundColor="{DynamicResource BgCard}"
                        StrokeShape="RoundRectangle 18">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LoginWithGoogleCommand}"/>
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="Auto,*" Padding="16,0">
                            <Label
                                Grid.Column="0"
                                Text="G"
                                FontFamily="DMSans-Bold"
                                FontSize="20"
                                TextColor="{DynamicResource TextPrimary}"
                                VerticalOptions="Center"/>

                            <Label
                                Grid.Column="1"
                                Text="Continuer avec Google"
                                FontFamily="DMSans-SemiBold"
                                FontSize="15"
                                TextColor="{DynamicResource TextPrimary}"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <Border
                        Style="{StaticResource BtnSecondary}"
                        Margin="0,4,0,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToRegisterCommand}"/>
                        </Border.GestureRecognizers>

                        <Label
                            Text="Créer un compte"
                            FontFamily="DMSans-SemiBold"
                            FontSize="15"
                            TextColor="{DynamicResource Accent}"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>
                    </Border>

                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
