<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NightOut.Views.Notifications.NotificationsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:NightOut.ViewModels"
    xmlns:models="clr-namespace:NightOut.Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:DataType="vm:NotificationsViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#0A1018">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" BackgroundColor="#0A1018">
        <Grid Grid.Row="0" Padding="16,50,16,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" BackgroundColor="#0D1520">
            <Button Grid.Column="0"
                    Text="‹"
                    FontSize="28"
                    WidthRequest="44"
                    HeightRequest="44"
                    Padding="0"
                    BackgroundColor="#1E2A38"
                    TextColor="#F2E8D5"
                    CornerRadius="12"
                    Command="{Binding BackCommand}"/>

            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                <Label Text="Notifications" FontSize="24" FontAttributes="Bold" TextColor="#F2E8D5"/>
                <Label Text="Demandes, groupes, sorties et invitations" FontSize="12" TextColor="#66768A"/>
                <Label Text="{Binding UnreadCount, StringFormat='{0} non lue(s)'}"
                       FontSize="11"
                       TextColor="#A855F7"
                       IsVisible="{Binding HasUnread}"/>
            </VerticalStackLayout>

            <Button Grid.Column="2"
                    Text="Tout lu"
                    BackgroundColor="#1E2A38"
                    TextColor="#F2E8D5"
                    CornerRadius="10"
                    Padding="10,6"
                    IsVisible="{Binding HasUnread}"
                    Command="{Binding MarkAllReadCommand}"/>
        </Grid>

        <RefreshView Grid.Row="1" Command="{Binding LoadCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Notifications}" Margin="16,12,16,20">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="0,60" Spacing="10" HorizontalOptions="Center">
                        <Label Text="🔔" FontSize="42" HorizontalOptions="Center"/>
                        <Label Text="Aucune notification" TextColor="#3D5068" FontSize="16" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:NightOutNotification">
                        <Border Padding="14"
                                Margin="0,6"
                                StrokeThickness="1"
                                Stroke="#1E2A38"
                                BackgroundColor="#111820"
                                StrokeShape="RoundRectangle 16">
                            <Grid ColumnDefinitions="42,*,Auto" ColumnSpacing="12">
                                <Border Grid.Column="0"
                                        WidthRequest="38"
                                        HeightRequest="38"
                                        StrokeThickness="0"
                                        BackgroundColor="#1E2A38"
                                        StrokeShape="RoundRectangle 19">
                                    <Label Text="{Binding Icon}" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label Text="{Binding DisplayTitle}" TextColor="#F2E8D5" FontAttributes="Bold" FontSize="15"/>
                                    <Label Text="{Binding DisplayMessage}" TextColor="#D8D1C1" FontSize="13" LineBreakMode="WordWrap"/>
                                    <Label Text="{Binding TimeAgo}" TextColor="#66768A" FontSize="11"/>
                                </VerticalStackLayout>

                                <Label Grid.Column="2"
                                       Text="●"
                                       TextColor="#A855F7"
                                       FontSize="18"
                                       IsVisible="{Binding IsRead, Converter={StaticResource InvertedBoolConverter}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
