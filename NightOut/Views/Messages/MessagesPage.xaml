<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NightOut.Views.Messages.MessagesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:NightOut.Views.Controls"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="{DynamicResource BgDeep}">

    <Grid RowDefinitions="*,Auto">
        <RefreshView Grid.Row="0" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
            <ScrollView>
                <VerticalStackLayout Padding="20,54,20,24" Spacing="18">

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Messages"
                                   FontSize="30"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                            <Label Text="Discute avec tes amis Spotiz"
                                   FontSize="13"
                                   TextColor="{DynamicResource TextSecondary}" />
                        </VerticalStackLayout>

                        <Button Grid.Column="1"
                                Text="↻"
                                WidthRequest="44"
                                HeightRequest="44"
                                CornerRadius="22"
                                BackgroundColor="{DynamicResource BgElevated}"
                                TextColor="{DynamicResource Accent}"
                                Command="{Binding RefreshCommand}" />
                    </Grid>

                    <Border BackgroundColor="{DynamicResource BgElevated}"
                            Stroke="{DynamicResource Border}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18"
                            Padding="14,2">
                        <Entry Text="{Binding SearchText}"
                               Placeholder="Rechercher un ami..."
                               PlaceholderColor="{DynamicResource TextMuted}"
                               TextColor="{DynamicResource TextPrimary}"
                               ClearButtonVisibility="WhileEditing" />
                    </Border>

                    <Label Text="{Binding StatusMessage}"
                           TextColor="{DynamicResource TextSecondary}"
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           IsVisible="{Binding IsEmpty}" />

                    <VerticalStackLayout Spacing="10" IsVisible="{Binding HasConversations}">
                        <Label Text="Conversations"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource TextPrimary}" />

                        <CollectionView ItemsSource="{Binding Conversations}"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="14"
                                            BackgroundColor="{DynamicResource BgElevated}"
                                            Stroke="{DynamicResource Border}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 20">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenConversationCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>

                                        <Grid ColumnDefinitions="48,*,Auto" ColumnSpacing="12">
                                            <controls:UserAvatar Grid.Column="0"
                                                                 AvatarSize="46"
                                                                 Name="{Binding Username}"
                                                                 AvatarUrl="{Binding AvatarUrl}" />

                                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                                <Label Text="{Binding Username}"
                                                       FontSize="16"
                                                       FontAttributes="Bold"
                                                       TextColor="{DynamicResource TextPrimary}" />
                                                <Label Text="{Binding LastMessage}"
                                                       FontSize="13"
                                                       TextColor="{DynamicResource TextSecondary}"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="2" Spacing="4" VerticalOptions="Center" HorizontalOptions="End">
                                                <Label Text="{Binding LastAtLabel}"
                                                       TextColor="{DynamicResource TextMuted}"
                                                       FontSize="11"
                                                       HorizontalTextAlignment="End" />
                                                <Border IsVisible="{Binding HasUnread}"
                                                        BackgroundColor="{DynamicResource Error}"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 10"
                                                        HeightRequest="20"
                                                        MinimumWidthRequest="20"
                                                        Padding="6,0"
                                                        HorizontalOptions="End">
                                                    <Label Text="{Binding UnreadCount}"
                                                           TextColor="White"
                                                           FontAttributes="Bold"
                                                           FontSize="11"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center" />
                                                </Border>
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="10" IsVisible="{Binding HasFriendsWithoutConversation}">
                        <Label Text="Démarrer une conversation"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource TextPrimary}" />

                        <CollectionView ItemsSource="{Binding FriendsWithoutConversation}"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="14"
                                            BackgroundColor="{DynamicResource BgCard}"
                                            Stroke="{DynamicResource Border}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 18">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenConversationCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>

                                        <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="12">
                                            <controls:UserAvatar Grid.Column="0"
                                                                 AvatarSize="42"
                                                                 Name="{Binding DisplayNameOrUsername}"
                                                                 AvatarUrl="{Binding AvatarUrl}" />

                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                                <Label Text="{Binding DisplayNameOrUsername}"
                                                       FontSize="15"
                                                       FontAttributes="Bold"
                                                       TextColor="{DynamicResource TextPrimary}" />
                                                <Label Text="{Binding Username}"
                                                       FontSize="12"
                                                       TextColor="{DynamicResource TextSecondary}" />
                                            </VerticalStackLayout>

                                            <Label Grid.Column="2"
                                                   Text="Écrire"
                                                   TextColor="{DynamicResource Accent}"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <controls:BottomNavBar Grid.Row="1" ActiveTab="Messages" />
    </Grid>
</ContentPage>
