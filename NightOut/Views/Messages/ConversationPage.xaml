<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NightOut.Views.Messages.ConversationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="{DynamicResource BgDeep}">

    <Grid RowDefinitions="Auto,*,Auto">

        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto"
              Padding="14,44,14,12"
              ColumnSpacing="12"
              BackgroundColor="{DynamicResource BgDeep}">

            <Button Grid.Column="0"
                    Text="‹"
                    WidthRequest="42"
                    HeightRequest="42"
                    CornerRadius="21"
                    FontSize="26"
                    Padding="0,-4,0,0"
                    BackgroundColor="{DynamicResource BgElevated}"
                    TextColor="{DynamicResource TextPrimary}"
                    Command="{Binding GoBackCommand}" />

            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                <Label Text="{Binding PartnerName}"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource TextPrimary}" />
                <Label Text="Message privé"
                       FontSize="12"
                       TextColor="{DynamicResource TextSecondary}" />
            </VerticalStackLayout>

            <Label Grid.Column="2"
                   Text="💬"
                   FontSize="24"
                   VerticalOptions="Center" />
        </Grid>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Messages}"
                        SelectionMode="None"
                        Margin="14,0"
                        VerticalOptions="Fill">
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="20" Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="💬" FontSize="42" HorizontalTextAlignment="Center" />
                    <Label Text="{Binding StatusMessage}" TextColor="{DynamicResource TextSecondary}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="0,5" HorizontalOptions="Fill">
                        <Border Padding="12,8"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                BackgroundColor="{DynamicResource BgElevated}"
                                MaximumWidthRequest="290"
                                HorizontalOptions="Start">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Content}"
                                       TextColor="{DynamicResource TextPrimary}"
                                       FontSize="15"
                                       LineBreakMode="WordWrap" />
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Button Text="Signaler"
                                            Padding="0"
                                            HeightRequest="22"
                                            MinimumHeightRequest="22"
                                            BackgroundColor="Transparent"
                                            TextColor="{DynamicResource Second}"
                                            FontSize="10"
                                            IsVisible="{Binding CanReport}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ReportMessageCommand}"
                                            CommandParameter="{Binding .}" />

                                    <Label Grid.Column="1"
                                           Text="{Binding TimeLabel}"
                                           TextColor="{DynamicResource TextSecondary}"
                                           FontSize="10"
                                           HorizontalTextAlignment="End" />
                                </Grid>
                            </VerticalStackLayout>

                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsMine}" Value="True">
                                    <Setter Property="HorizontalOptions" Value="End" />
                                    <Setter Property="BackgroundColor" Value="{DynamicResource Accent}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsMine}" Value="False">
                                    <Setter Property="HorizontalOptions" Value="Start" />
                                    <Setter Property="BackgroundColor" Value="{DynamicResource BgElevated}" />
                                </DataTrigger>
                            </Border.Triggers>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto"
              Padding="12,10,12,14"
              ColumnSpacing="10"
              BackgroundColor="{DynamicResource BgDeep}">

            <Border Grid.Column="0"
                    BackgroundColor="{DynamicResource BgElevated}"
                    Stroke="{DynamicResource Border}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 22"
                    Padding="14,0">
                <Entry Text="{Binding NewMessage}"
                       Placeholder="Écrire un message..."
                       PlaceholderColor="{DynamicResource TextMuted}"
                       TextColor="{DynamicResource TextPrimary}"
                       ReturnType="Send"
                       ReturnCommand="{Binding SendCommand}" />
            </Border>

            <Button Grid.Column="1"
                    Text="➤"
                    WidthRequest="46"
                    HeightRequest="46"
                    CornerRadius="23"
                    FontSize="18"
                    BackgroundColor="{DynamicResource Accent}"
                    TextColor="{DynamicResource BgDeep}"
                    Command="{Binding SendCommand}" />
        </Grid>
    </Grid>
</ContentPage>
