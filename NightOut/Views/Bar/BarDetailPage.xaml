<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NightOut.Views.Bar.BarDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:NightOut.ViewModels"
    xmlns:models="clr-namespace:NightOut.Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
    x:DataType="vm:BarDetailViewModel"
    x:Name="PageRoot"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{DynamicResource BgElevated}">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="Inv" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*">
        <ScrollView>
            <VerticalStackLayout Spacing="0" Padding="0,0,0,26">

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{DynamicResource Accent}"
                                   Margin="0,70,0,20" />

                <!-- HERO façon Spotiz Premium -->
                <Grid HeightRequest="405"
                      IsVisible="{Binding IsBusy, Converter={StaticResource Inv}}">
                    <Image Source="{Binding CoverUrl}"
                           Aspect="AspectFill"
                           IsVisible="{Binding HasCover}" />

                    <Grid IsVisible="{Binding HasCover, Converter={StaticResource Inv}}">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{DynamicResource BgPanel}" Offset="0" />
                                <GradientStop Color="{DynamicResource BgElevated}" Offset="1" />
                            </LinearGradientBrush>
                        </Grid.Background>
                    </Grid>

                    <BoxView>
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#222A1B10" Offset="0" />
                                <GradientStop Color="#662A1B10" Offset="0.38" />
                                <GradientStop Color="{DynamicResource BgDeep}" Offset="1" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- top buttons -->
                    <Grid Padding="20,54,20,0"
                          ColumnDefinitions="48,*,48,48"
                          ColumnSpacing="10"
                          VerticalOptions="Start">
                        <Border BackgroundColor="{DynamicResource AccentDim}"
                                Stroke="{DynamicResource Border}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 24"
                                WidthRequest="46"
                                HeightRequest="46">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="‹" TextColor="{DynamicResource TextPrimary}" FontSize="34"
                                   HorizontalOptions="Center" VerticalOptions="Center" Margin="0,-4,0,0" />
                        </Border>

                        <Border Grid.Column="2"
                                BackgroundColor="{DynamicResource AccentDim}"
                                Stroke="{DynamicResource Border}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 24"
                                WidthRequest="46"
                                HeightRequest="46">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding RefreshCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="↻" TextColor="{DynamicResource TextPrimary}" FontSize="20"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>

                        <Border Grid.Column="3"
                                BackgroundColor="{DynamicResource AccentDim}"
                                Stroke="{DynamicResource Border}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 24"
                                WidthRequest="46"
                                HeightRequest="46">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleFollowBarCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="♡" TextColor="{DynamicResource TextPrimary}" FontSize="24"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <!-- identity -->
                    <VerticalStackLayout VerticalOptions="End" Padding="20,0,20,26" Spacing="16">
                        <Grid ColumnDefinitions="96,*" ColumnSpacing="16">
                            <Border WidthRequest="92" HeightRequest="92"
                                    BackgroundColor="{DynamicResource BgCard}"
                                    Stroke="{DynamicResource Accent}"
                                    StrokeThickness="1.4"
                                    StrokeShape="RoundRectangle 28"
                                    VerticalOptions="End">
                                <Grid>
                                    <Image Source="{Binding LogoUrl}" Aspect="AspectFill" IsVisible="{Binding HasLogo}" />
                                    <Label Text="{Binding BarName}" TextColor="{DynamicResource Accent}" FontSize="11" FontAttributes="Bold"
                                           HorizontalOptions="Center" VerticalOptions="Center" HorizontalTextAlignment="Center"
                                           IsVisible="{Binding HasLogo, Converter={StaticResource Inv}}" />
                                </Grid>
                            </Border>

                            <VerticalStackLayout Grid.Column="1" VerticalOptions="End" Spacing="6">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="{Binding BarName}" FontFamily="DMSans-Bold" FontSize="30" TextColor="{DynamicResource TextPrimary}" LineBreakMode="TailTruncation" />
                                    <Label Text="●" TextColor="{DynamicResource Accent}" FontSize="15" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding BarType}" TextColor="{DynamicResource TextPrimary}" FontSize="15" />
                            </VerticalStackLayout>
                        </Grid>

                        <FlexLayout Wrap="Wrap" Direction="Row" AlignItems="Start">
                            <Border Margin="0,0,8,8" Padding="10,6" BackgroundColor="{DynamicResource BgElevated}" StrokeThickness="0" StrokeShape="RoundRectangle 16">
                                <Label Text="{Binding OpenStatusShortText}" TextColor="{DynamicResource Success}" FontSize="14" FontAttributes="Bold" />
                            </Border>
                            <Border Margin="0,0,8,8" Padding="10,6" BackgroundColor="{DynamicResource BgPanel}" StrokeThickness="0" StrokeShape="RoundRectangle 16">
                                <Label Text="{Binding PresentCountLabel}" TextColor="{DynamicResource TextPrimary}" FontSize="14" />
                            </Border>
                            <Border Margin="0,0,8,8" Padding="10,6" BackgroundColor="{DynamicResource BgCard}" StrokeThickness="0" StrokeShape="RoundRectangle 16">
                                <Label Text="{Binding AmbianceLabel}" TextColor="{DynamicResource Accent}" FontSize="14" FontAttributes="Bold" />
                            </Border>
                        </FlexLayout>

                        <!-- Action principale fiche bar : les actions pratiques restent sur la vignette carte -->
                        <Grid ColumnDefinitions="*,2.2*,*">
                            <Button Grid.Column="1"
                                    Text="{Binding FollowButtonText}"
                                    Command="{Binding ToggleFollowBarCommand}"
                                    BackgroundColor="{Binding FollowButtonBackgroundColor}"
                                    TextColor="{Binding FollowButtonTextColor}"
                                    FontFamily="DMSans-Bold"
                                    CornerRadius="18"
                                    HeightRequest="54"
                                    HorizontalOptions="Fill" />
                        </Grid>
                    </VerticalStackLayout>
                </Grid>

                <!-- RÉCOMPENSES : action commerciale visible, hors onglet Infos -->
                <VerticalStackLayout Margin="20,0,20,18"
                                     Spacing="10"
                                     IsVisible="{Binding HasRewards}">
                    <Border Padding="16"
                            BackgroundColor="{DynamicResource BgCard}"
                            Stroke="#55CEA358"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 24">
                        <VerticalStackLayout Spacing="14">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border WidthRequest="44" HeightRequest="44"
                                        BackgroundColor="{DynamicResource BgCard}"
                                        Stroke="#33CEA358"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 22">
                                    <Label Text="🎁"
                                           FontSize="22"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="Récompenses disponibles"
                                           TextColor="{DynamicResource TextPrimary}"
                                           FontFamily="DMSans-Bold"
                                           FontSize="18" />
                                    <Label Text="Utilise tes points directement dans ce bar"
                                           TextColor="{DynamicResource TextSecondary}"
                                           FontSize="12" />
                                </VerticalStackLayout>

                                <Border Grid.Column="2"
                                        Padding="10,6"
                                        BackgroundColor="{DynamicResource BgDeep}"
                                        Stroke="{DynamicResource Accent}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 16">
                                    <Label Text="Spotiz"
                                           TextColor="{DynamicResource Accent}"
                                           FontFamily="DMSans-Bold"
                                           FontSize="12" />
                                </Border>
                            </Grid>

                            <!-- QR / code généré après clic sur Utiliser -->
                            <Border BackgroundColor="{DynamicResource TextPrimary}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 22"
                                    Padding="16"
                                    IsVisible="{Binding HasRewardIntent}">
                                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                                    <Grid ColumnDefinitions="*,Auto" HorizontalOptions="Fill">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="{Binding RewardIntentTitle}"
                                                   TextColor="{DynamicResource BgDeep}"
                                                   FontFamily="DMSans-Bold"
                                                   FontSize="16" />
                                            <Label Text="{Binding RewardIntentCostLabel}"
                                                   TextColor="{DynamicResource TextSecondary}"
                                                   FontFamily="DMSans-Bold"
                                                   FontSize="12" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1"
                                               Text="×"
                                               TextColor="{DynamicResource BgDeep}"
                                               FontSize="24"
                                               VerticalOptions="Start">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding CloseRewardIntentCommand}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Grid>

                                    <Label Text="QR CODE À PRÉSENTER AU BAR"
                                           TextColor="{DynamicResource BgDeep}"
                                           FontFamily="DMSans-Bold"
                                           FontSize="11"
                                           HorizontalOptions="Center" />

                                    <zxing:BarcodeGeneratorView WidthRequest="185"
                                                                HeightRequest="185"
                                                                Format="QrCode"
                                                                Value="{Binding RewardIntentQrPayload}"
                                                                ForegroundColor="Black"
                                                                BackgroundColor="White"
                                                                HorizontalOptions="Center" />

                                    <Label Text="Code secours"
                                           TextColor="{DynamicResource TextMuted}"
                                           FontFamily="DMSans-SemiBold"
                                           FontSize="10"
                                           HorizontalOptions="Center" />
                                    <Label Text="{Binding RewardIntentShortCode}"
                                           TextColor="{DynamicResource BgDeep}"
                                           FontFamily="DMSans-Bold"
                                           FontSize="24"
                                           CharacterSpacing="4"
                                           HorizontalOptions="Center" />
                                    <Label Text="{Binding RewardIntentExpiresLabel}"
                                           TextColor="{DynamicResource TextMuted}"
                                           FontSize="11"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>

                            <!-- Liste des récompenses -->
                            <CollectionView ItemsSource="{Binding Rewards}"
                                            SelectionMode="None"
                                            MaximumHeightRequest="260">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:BarReward">
                                        <Border Margin="0,0,0,8"
                                                Padding="12"
                                                BackgroundColor="{DynamicResource BgElevated}"
                                                Stroke="{DynamicResource Border}"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 18">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                <VerticalStackLayout Spacing="3" VerticalOptions="Center">
                                                    <Label Text="{Binding Title}"
                                                           TextColor="{DynamicResource TextPrimary}"
                                                           FontFamily="DMSans-Bold"
                                                           FontSize="14" />
                                                    <Label Text="{Binding DescriptionLabel}"
                                                           TextColor="{DynamicResource TextSecondary}"
                                                           FontSize="11"
                                                           LineBreakMode="WordWrap"
                                                           MaxLines="2" />
                                                    <Label Text="{Binding CostLabel}"
                                                           TextColor="{DynamicResource Accent}"
                                                           FontFamily="DMSans-Bold"
                                                           FontSize="12" />
                                                </VerticalStackLayout>

                                                <Button Grid.Column="1"
                                                        Text="Utiliser"
                                                        Command="{Binding BindingContext.PrepareRewardCommand, Source={x:Reference PageRoot}}"
                                                        CommandParameter="{Binding .}"
                                                        BackgroundColor="{DynamicResource Accent}"
                                                        TextColor="{DynamicResource BgDeep}"
                                                        FontFamily="DMSans-Bold"
                                                        FontSize="12"
                                                        CornerRadius="16"
                                                        Padding="12,8"
                                                        VerticalOptions="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ONGLET REEL AMBIANCE / PRESENTS -->
                <Grid Margin="20,0,20,18" HeightRequest="58" ColumnDefinitions="*,*"
                      IsVisible="{Binding IsBusy, Converter={StaticResource Inv}}">
                    <Border Grid.ColumnSpan="2" BackgroundColor="{DynamicResource BgCard}" Stroke="{DynamicResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 18" />

                    <!-- Ambiance active -->
                    <Border BackgroundColor="{DynamicResource BgDeep}" Stroke="{DynamicResource Accent}" StrokeThickness="1" StrokeShape="RoundRectangle 18"
                            IsVisible="{Binding IsAmbianceTabSelected}">
                        <Label Text="🔥 Ambiance" TextColor="{DynamicResource Accent}" FontFamily="DMSans-Bold" FontSize="15"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                    <!-- Presents active -->
                    <Border Grid.Column="1" BackgroundColor="{DynamicResource BgDeep}" Stroke="{DynamicResource Accent}" StrokeThickness="1" StrokeShape="RoundRectangle 18"
                            IsVisible="{Binding IsInfosTabSelected}">
                        <Label Text="Présents" TextColor="{DynamicResource Accent}" FontFamily="DMSans-Bold" FontSize="15"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                    <!-- Zones cliquables -->
                    <Grid>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectAmbianceTabCommand}" />
                        </Grid.GestureRecognizers>
                        <Label Text="🔥 Ambiance" TextColor="{DynamicResource TextPrimary}" FontFamily="DMSans-Bold" FontSize="15"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               IsVisible="{Binding IsAmbianceTabSelected, Converter={StaticResource Inv}}" />
                    </Grid>
                    <Grid Grid.Column="1">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectInfosTabCommand}" />
                        </Grid.GestureRecognizers>
                        <Label Text="Présents" TextColor="{DynamicResource TextPrimary}" FontFamily="DMSans-Bold" FontSize="15"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               IsVisible="{Binding IsInfosTabSelected, Converter={StaticResource Inv}}" />
                    </Grid>
                </Grid>

                <VerticalStackLayout IsVisible="{Binding IsAmbianceTabSelected}" Spacing="0">
                <!-- AMBIANCE DU MOMENT / COMPOSER -->
                <Border Margin="20,0,20,14" Padding="16"
                        BackgroundColor="{DynamicResource BgDeep}" Stroke="{DynamicResource Border}" StrokeThickness="1"
                        StrokeShape="RoundRectangle 24"
                        IsVisible="{Binding IsBusy, Converter={StaticResource Inv}}">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="🔥 Ambiance du moment" TextColor="{DynamicResource Accent}" FontFamily="DMSans-Bold" FontSize="22" />
                                <Label Text="{Binding FeedSubtitle}" TextColor="{DynamicResource TextSecondary}" FontSize="13" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1" Padding="10,6" BackgroundColor="{DynamicResource Border}" StrokeThickness="0" StrokeShape="RoundRectangle 16">
                                <Label Text="● EN DIRECT" TextColor="{DynamicResource Error}" FontSize="11" FontFamily="DMSans-Bold" />
                            </Border>
                        </Grid>

                        <HorizontalStackLayout Spacing="-10" IsVisible="{Binding HasFriendsHere}">
                            <CollectionView ItemsSource="{Binding FriendsHere}" HeightRequest="38" WidthRequest="170" SelectionMode="None">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="-9" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:Profile">
                                        <Border WidthRequest="36" HeightRequest="36" Stroke="{DynamicResource BgDeep}" StrokeThickness="2" StrokeShape="RoundRectangle 18" BackgroundColor="{DynamicResource BgElevated}">
                                            <Image Source="{Binding AvatarUrl}" Aspect="AspectFill" />
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                            <Border Padding="10,0" HeightRequest="36" BackgroundColor="{DynamicResource BgElevated}" Stroke="{DynamicResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 18">
                                <Label Text="{Binding FriendsHerePlusLabel}" TextColor="{DynamicResource TextPrimary}" FontSize="13" VerticalOptions="Center" />
                            </Border>
                        </HorizontalStackLayout>

                        <Border BackgroundColor="{DynamicResource BgCard}" Stroke="{DynamicResource BgElevated}" StrokeThickness="1" StrokeShape="RoundRectangle 18">
                            <Grid RowDefinitions="Auto,56" ColumnDefinitions="*,56">
                                <Editor Grid.ColumnSpan="2" Text="{Binding MessageText}"
                                        Placeholder="Publier un message, une photo ou une vidéo..."
                                        PlaceholderColor="{DynamicResource TextSecondary}" TextColor="{DynamicResource TextPrimary}"
                                        AutoSize="TextChanges" MinimumHeightRequest="72"
                                        BackgroundColor="Transparent" Margin="12,8" />
                                <Grid Grid.Row="1" Grid.ColumnSpan="2" BackgroundColor="{DynamicResource BgDeep}" ColumnDefinitions="*,*,56">
                                    <Button Text="▣ Photo" Command="{Binding PostPhotoCommand}"
                                            BackgroundColor="Transparent" TextColor="{DynamicResource Accent}" FontFamily="DMSans-Bold" />
                                    <Button Grid.Column="1" Text="▣ Vidéo" Command="{Binding PostVideoCommand}"
                                            BackgroundColor="Transparent" TextColor="{DynamicResource Accent}" FontFamily="DMSans-Bold" />
                                    <Button Grid.Column="2" Text="➤" Command="{Binding PostMessageCommand}"
                                            BackgroundColor="{DynamicResource Accent}" TextColor="{DynamicResource BgDeep}" FontSize="20"
                                            CornerRadius="24" Margin="7" />
                                </Grid>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- FEED -->
                <CollectionView ItemsSource="{Binding Feed}"
                                Margin="20,0,20,0"
                                SelectionMode="None"
                                IsVisible="{Binding IsBusy, Converter={StaticResource Inv}}">
                    <CollectionView.EmptyView>
                        <Border Padding="22" BackgroundColor="{DynamicResource BgDeep}" Stroke="{DynamicResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 24">
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Label Text="Aucune ambiance pour le moment" TextColor="{DynamicResource TextPrimary}" FontFamily="DMSans-Bold" FontSize="18" HorizontalTextAlignment="Center" />
                                <Label Text="Sois le premier à partager une photo, une vidéo ou un message." TextColor="{DynamicResource TextSecondary}" FontSize="13" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:BarActivityItem">
                            <Border Margin="0,0,0,16"
                                    Padding="0"
                                    BackgroundColor="{DynamicResource BgDeep}"
                                    Stroke="{DynamicResource Border}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 24">
                                <VerticalStackLayout Spacing="0">
                                    <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="10" Padding="14,14,14,10">
                                        <Border WidthRequest="48" HeightRequest="48"
                                                Stroke="{DynamicResource BgCard}"
                                                StrokeThickness="1.4"
                                                StrokeShape="RoundRectangle 24"
                                                BackgroundColor="{DynamicResource BgElevated}">
                                            <Grid>
                                                <Image Source="{Binding AvatarUrl}" Aspect="AspectFill" IsVisible="{Binding HasAvatarUrl}" />
                                                <Label Text="{Binding Initials}" TextColor="{DynamicResource Accent}" FontFamily="DMSans-Bold" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="{Binding HasAvatarUrl, Converter={StaticResource Inv}}" />
                                            </Grid>
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" Spacing="1">
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="{Binding Username}" TextColor="{DynamicResource TextPrimary}" FontFamily="DMSans-Bold" FontSize="15" />
                                                <Label Text="●" TextColor="{DynamicResource Success}" FontSize="10" VerticalOptions="Center" IsVisible="{Binding OpenToMeet}" />
                                            </HorizontalStackLayout>
                                            <Label Text="{Binding TimeAgo}" TextColor="{DynamicResource TextSecondary}" FontSize="12" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="•••" TextColor="{DynamicResource TextSecondary}" FontSize="18" />
                                    </Grid>

                                    <Label Text="{Binding DisplayText}"
                                           TextColor="{DynamicResource TextPrimary}"
                                           FontSize="15"
                                           LineBreakMode="WordWrap"
                                           IsVisible="{Binding HasDisplayText}"
                                           Margin="14,0,14,12" />

                                    <!-- Photo style réseau social : hauteur naturelle, pas de découpe, limite max -->
                                    <Border IsVisible="{Binding IsPhoto}"
                                            Margin="0,0,0,0"
                                            Padding="0"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 0"
                                            BackgroundColor="{DynamicResource BgElevated}">
                                        <Grid BackgroundColor="{DynamicResource BgElevated}"
                                              MinimumHeightRequest="180"
                                              MaximumHeightRequest="560">
                                            <Image Source="{Binding MediaUrl}"
                                                   Aspect="AspectFit"
                                                   BackgroundColor="{DynamicResource BgElevated}"
                                                   HorizontalOptions="Fill"
                                                   VerticalOptions="Center"
                                                   MaximumHeightRequest="560" />
                                        </Grid>
                                    </Border>

                                    <!-- Lecteur vidéo HTML5 intégré, format feed premium -->
                                    <Border IsVisible="{Binding IsVideo}"
                                            HeightRequest="360"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 0"
                                            BackgroundColor="{DynamicResource BgDeep}">
                                        <Grid BackgroundColor="{DynamicResource BgDeep}">
                                            <WebView Source="{Binding VideoSource}" />
                                        </Grid>
                                    </Border>

                                    <Border IsVisible="{Binding IsCheckin}"
                                            Margin="14,0,14,0"
                                            Padding="12"
                                            BackgroundColor="{DynamicResource BgCard}"
                                            Stroke="{DynamicResource BorderMid}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 16">
                                        <Grid ColumnDefinitions="36,*" ColumnSpacing="10">
                                            <Border WidthRequest="32"
                                                    HeightRequest="32"
                                                    BackgroundColor="{DynamicResource AccentSoft}"
                                                    Stroke="{DynamicResource Accent}"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 16">
                                                <Label Text="⌖"
                                                       TextColor="{DynamicResource Accent}"
                                                       FontSize="17"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                <Label Text="{Binding CheckinTitle}"
                                                       TextColor="{DynamicResource Accent}"
                                                       FontFamily="DMSans-Bold"
                                                       FontSize="12" />
                                                <Label Text="{Binding Content}"
                                                       TextColor="{DynamicResource TextPrimary}"
                                                       FontSize="13"
                                                       LineBreakMode="WordWrap" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>

                                    <!-- Actions style Instagram / Spotiz -->
                                    <VerticalStackLayout Margin="14,12,14,14" Spacing="8">
                                        <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto" ColumnSpacing="18">
                                            <Label Text="♥"
                                                   TextColor="{DynamicResource Error}"
                                                   FontSize="25"
                                                   VerticalOptions="Center">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding BindingContext.ToggleLikeCommand, Source={x:Reference PageRoot}}" CommandParameter="{Binding .}" />
                                                </Label.GestureRecognizers>
                                            </Label>

                                            <Label Grid.Column="1"
                                                   Text="💬"
                                                   TextColor="{DynamicResource TextPrimary}"
                                                   FontSize="21"
                                                   VerticalOptions="Center">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding BindingContext.OpenCommentsCommand, Source={x:Reference PageRoot}}" CommandParameter="{Binding .}" />
                                                </Label.GestureRecognizers>
                                            </Label>

                                            <Label Grid.Column="2"
                                                   Text="↗"
                                                   TextColor="{DynamicResource TextPrimary}"
                                                   FontSize="24"
                                                   VerticalOptions="Center" />

                                            <Button Grid.Column="4"
                                                    Text="Ajouter"
                                                    Command="{Binding BindingContext.AddFriendCommand, Source={x:Reference PageRoot}}"
                                                    CommandParameter="{Binding .}"
                                                    IsVisible="{Binding CanAddAsFriend}"
                                                    BackgroundColor="{DynamicResource BgPanel}"
                                                    BorderColor="{DynamicResource Accent}"
                                                    BorderWidth="1"
                                                    TextColor="{DynamicResource Accent}"
                                                    FontSize="12"
                                                    CornerRadius="14"
                                                    HeightRequest="34"
                                                    Padding="10,0" />
                                        </Grid>

                                        <Label Text="{Binding LikeLabel}"
                                               TextColor="{DynamicResource TextPrimary}"
                                               FontFamily="DMSans-Bold"
                                               FontSize="13"
                                               IsVisible="{Binding IsMedia}" />

                                        <Label Text="{Binding CommentLabel}"
                                               TextColor="{DynamicResource TextMuted}"
                                               FontSize="13">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding BindingContext.OpenCommentsCommand, Source={x:Reference PageRoot}}" CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Text="Voir plus de publications⌄"
                        Margin="20,0,20,22"
                        BackgroundColor="{DynamicResource BgDeep}"
                        BorderColor="{DynamicResource Border}"
                        BorderWidth="1"
                        TextColor="{DynamicResource Accent}"
                        FontFamily="DMSans-Bold"
                        CornerRadius="18"
                        HeightRequest="52"
                        Command="{Binding RefreshCommand}"
                        IsVisible="{Binding IsBusy, Converter={StaticResource Inv}}" />
                </VerticalStackLayout>
                <!-- UTILISATEURS PRESENTS -->
                <VerticalStackLayout x:Name="InfosSection" Spacing="14" Padding="20,0,20,0" IsVisible="{Binding IsInfosTabSelected}">
                    <Border Padding="18" BackgroundColor="{DynamicResource BgDeep}" Stroke="{DynamicResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 24">
                        <VerticalStackLayout Spacing="16">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="Ici maintenant" TextColor="{DynamicResource TextPrimary}" FontFamily="DMSans-Bold" FontSize="22" />
                                    <Label Text="{Binding PresentUsersCountLabel}" TextColor="{DynamicResource TextSecondary}" FontSize="13" />
                                </VerticalStackLayout>
                                <Border Grid.Column="1" Padding="10,6" BackgroundColor="{DynamicResource AccentSoft}" StrokeThickness="0" StrokeShape="RoundRectangle 16">
                                    <Label Text="Visible" TextColor="{DynamicResource Accent}" FontFamily="DMSans-Bold" FontSize="11" />
                                </Border>
                            </Grid>

                            <CollectionView ItemsSource="{Binding PresentUsers}" SelectionMode="None" IsVisible="{Binding HasPresentUsers}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:BarPresentUserItem">
                                        <Border Margin="0,0,0,10" Padding="12" BackgroundColor="{DynamicResource BgCard}" Stroke="{DynamicResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 18">
                                            <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="12">
                                                <Border WidthRequest="48" HeightRequest="48" BackgroundColor="{DynamicResource BgElevated}" Stroke="{DynamicResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 24">
                                                    <Grid>
                                                        <Image Source="{Binding AvatarUrl}" Aspect="AspectFill" IsVisible="{Binding HasAvatar}" />
                                                        <Label Text="{Binding Initials}" TextColor="{DynamicResource Accent}" FontFamily="DMSans-Bold" FontSize="15" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="{Binding HasAvatar, Converter={StaticResource Inv}}" />
                                                    </Grid>
                                                </Border>

                                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                    <Label Text="{Binding DisplayName}" TextColor="{DynamicResource TextPrimary}" FontFamily="DMSans-Bold" FontSize="15" LineBreakMode="TailTruncation" />
                                                    <Label Text="{Binding Username}" TextColor="{DynamicResource TextMuted}" FontSize="12" LineBreakMode="TailTruncation" />
                                                    <Label Text="{Binding Subtitle}" TextColor="{DynamicResource TextSecondary}" FontSize="12" />
                                                </VerticalStackLayout>

                                                <Button Grid.Column="2"
                                                        Text="{Binding RelationshipLabel}"
                                                        Command="{Binding BindingContext.RequestFriendFromPresentUserCommand, Source={x:Reference PageRoot}}"
                                                        CommandParameter="{Binding .}"
                                                        IsEnabled="{Binding CanRequestFriend}"
                                                        BackgroundColor="{Binding RelationshipButtonBackground}"
                                                        TextColor="{Binding RelationshipButtonTextColor}"
                                                        FontFamily="DMSans-Bold"
                                                        FontSize="12"
                                                        CornerRadius="16"
                                                        Padding="12,0"
                                                        HeightRequest="34"
                                                        VerticalOptions="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <Border Padding="18" BackgroundColor="{DynamicResource BgCard}" Stroke="{DynamicResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 18" IsVisible="{Binding HasPresentUsers, Converter={StaticResource Inv}}">
                                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                    <Label Text="Personne de visible pour le moment" TextColor="{DynamicResource TextPrimary}" FontFamily="DMSans-Bold" FontSize="16" HorizontalTextAlignment="Center" />
                                    <Label Text="Les utilisateurs en mode fantôme ou sans partage social ne sont jamais affichés ici." TextColor="{DynamicResource TextSecondary}" FontSize="12" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>


