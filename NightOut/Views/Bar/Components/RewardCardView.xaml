<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="NightOut.Views.Bar.Components.RewardCardView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:NightOut.Models"
    xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
    x:Name="RewardRoot">

    <Border Padding="16"
            BackgroundColor="{DynamicResource BgCard}"
            Stroke="#55CEA358"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 24">
        <VerticalStackLayout Spacing="14">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <Border WidthRequest="44"
                        HeightRequest="44"
                        BackgroundColor="{DynamicResource BgCard}"
                        Stroke="#33CEA358"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 22">
                    <Label Text="🎁"
                           FontSize="22"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Text="Récompenses disponibles"
                           TextColor="White"
                           FontFamily="DMSans-Bold"
                           FontSize="18" />
                    <Label Text="Utilise tes points directement dans ce bar"
                           TextColor="{DynamicResource TextSecondary}"
                           FontSize="12" />
                </VerticalStackLayout>

                <Border Grid.Column="2"
                        Padding="10,6"
                        BackgroundColor="{DynamicResource BgDeep}"
                        Stroke="{DynamicResource Accent}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16">
                    <Label Text="Spotiz"
                           TextColor="{DynamicResource Accent}"
                           FontFamily="DMSans-Bold"
                           FontSize="12" />
                </Border>
            </Grid>

            <Border BackgroundColor="{DynamicResource TextPrimary}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 22"
                    Padding="16"
                    IsVisible="{Binding Source={x:Reference RewardRoot}, Path=HasRewardIntent}">
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Grid ColumnDefinitions="*,Auto" HorizontalOptions="Fill">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding Source={x:Reference RewardRoot}, Path=RewardIntentTitle}"
                                   TextColor="{DynamicResource BgDeep}"
                                   FontFamily="DMSans-Bold"
                                   FontSize="16" />
                            <Label Text="{Binding Source={x:Reference RewardRoot}, Path=RewardIntentCostLabel}"
                                   TextColor="{DynamicResource TextSecondary}"
                                   FontFamily="DMSans-Bold"
                                   FontSize="12" />
                        </VerticalStackLayout>
                        <Label Grid.Column="1"
                               Text="×"
                               TextColor="{DynamicResource BgDeep}"
                               FontSize="24"
                               VerticalOptions="Start">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={x:Reference RewardRoot}, Path=CloseRewardIntentCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <Label Text="QR CODE À PRÉSENTER AU BAR"
                           TextColor="{DynamicResource BgDeep}"
                           FontFamily="DMSans-Bold"
                           FontSize="11"
                           HorizontalOptions="Center" />

                    <zxing:BarcodeGeneratorView WidthRequest="185"
                                                HeightRequest="185"
                                                Format="QrCode"
                                                Value="{Binding Source={x:Reference RewardRoot}, Path=RewardIntentQrPayload}"
                                                ForegroundColor="Black"
                                                BackgroundColor="White"
                                                HorizontalOptions="Center" />

                    <Label Text="Code secours"
                           TextColor="{DynamicResource TextMuted}"
                           FontFamily="DMSans-SemiBold"
                           FontSize="10"
                           HorizontalOptions="Center" />
                    <Label Text="{Binding Source={x:Reference RewardRoot}, Path=RewardIntentShortCode}"
                           TextColor="{DynamicResource BgDeep}"
                           FontFamily="DMSans-Bold"
                           FontSize="24"
                           CharacterSpacing="4"
                           HorizontalOptions="Center" />
                    <Label Text="{Binding Source={x:Reference RewardRoot}, Path=RewardIntentExpiresLabel}"
                           TextColor="{DynamicResource TextMuted}"
                           FontSize="11"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <CollectionView ItemsSource="{Binding Source={x:Reference RewardRoot}, Path=Rewards}"
                            SelectionMode="None"
                            MaximumHeightRequest="260">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:BarReward">
                        <Border Margin="0,0,0,8"
                                Padding="12"
                                BackgroundColor="{DynamicResource BgElevated}"
                                Stroke="{DynamicResource Border}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 18">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <VerticalStackLayout Spacing="3" VerticalOptions="Center">
                                    <Label Text="{Binding Title}"
                                           TextColor="White"
                                           FontFamily="DMSans-Bold"
                                           FontSize="14" />
                                    <Label Text="{Binding DescriptionLabel}"
                                           TextColor="{DynamicResource TextSecondary}"
                                           FontSize="11"
                                           LineBreakMode="WordWrap"
                                           MaxLines="2" />
                                    <Label Text="{Binding CostLabel}"
                                           TextColor="{DynamicResource Accent}"
                                           FontFamily="DMSans-Bold"
                                           FontSize="12" />
                                </VerticalStackLayout>

                                <Button Grid.Column="1"
                                        Text="Utiliser"
                                        Command="{Binding Source={x:Reference RewardRoot}, Path=PrepareRewardCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="{DynamicResource Accent}"
                                        TextColor="{DynamicResource BgDeep}"
                                        FontFamily="DMSans-Bold"
                                        FontSize="12"
                                        CornerRadius="16"
                                        Padding="12,8"
                                        VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </Border>
</ContentView>
