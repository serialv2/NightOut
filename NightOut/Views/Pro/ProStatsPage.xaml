<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NightOut.Views.Pro.ProStatsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:NightOut.ViewModels"
    xmlns:models="clr-namespace:NightOut.Models"
    x:DataType="vm:ProStatsViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#0A1018">

    <ContentPage.Resources>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#131C28"/>
            <Setter Property="Stroke" Value="#1F2D3D"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 18"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0"
              BackgroundColor="#0D1520"
              Padding="20,50,20,22"
              ColumnDefinitions="Auto,*"
              ColumnSpacing="14">

            <Border Grid.Column="0"
                    BackgroundColor="#1A2535"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 22"
                    WidthRequest="44"
                    HeightRequest="44">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding BackCommand}"/>
                </Border.GestureRecognizers>

                <Label Text="‹"
                       FontSize="28"
                       TextColor="#FFB627"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                <Label Text="Statistiques Pro"
                       FontFamily="DMSans-SemiBold"
                       FontSize="22"
                       TextColor="#F2E8D5"/>

                <Label Text="{Binding ProName}"
                       FontFamily="DMSans-Regular"
                       FontSize="13"
                       TextColor="#3D5068"/>
            </VerticalStackLayout>
        </Grid>

        <RefreshView Grid.Row="1"
                     Command="{Binding LoadCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <ScrollView>
                <VerticalStackLayout Padding="20,16,20,28" Spacing="14">

                    <Border BackgroundColor="#181C26"
                            Stroke="#FFB627"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 22"
                            Padding="18">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Vue globale"
                                   FontFamily="DMSans-SemiBold"
                                   FontSize="18"
                                   TextColor="#F2E8D5"/>

                            <Label Text="{Binding StatusLabel}"
                                   FontFamily="DMSans-Regular"
                                   FontSize="13"
                                   TextColor="#FFB627"/>

                            <Label Text="{Binding CheckInRateLabel}"
                                   FontFamily="DMSans-Regular"
                                   FontSize="13"
                                   TextColor="#A8B3C3"
                                   LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource StatCard}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="📅" FontSize="24"/>
                                <Label Text="{Binding TotalEvents}" FontSize="24" FontFamily="DMSans-SemiBold" TextColor="#F2E8D5"/>
                                <Label Text="Événements" FontSize="12" TextColor="#A8B3C3"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource StatCard}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="🎉" FontSize="24"/>
                                <Label Text="{Binding TotalGoing}" FontSize="24" FontFamily="DMSans-SemiBold" TextColor="#F2E8D5"/>
                                <Label Text="J'y vais" FontSize="12" TextColor="#A8B3C3"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource StatCard}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="📍" FontSize="24"/>
                                <Label Text="{Binding TotalCheckedIn}" FontSize="24" FontFamily="DMSans-SemiBold" TextColor="#F2E8D5"/>
                                <Label Text="Check-ins GPS" FontSize="12" TextColor="#A8B3C3"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource StatCard}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="⭐" FontSize="24"/>
                                <Label Text="{Binding AverageReliabilityLabel}" FontSize="24" FontFamily="DMSans-SemiBold" TextColor="#F2E8D5"/>
                                <Label Text="Fiabilité événements terminés" FontSize="11" TextColor="#A8B3C3"/>
                                <Label Text="{Binding AverageReliabilityBadge}" FontSize="12" TextColor="#FFB627"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Border BackgroundColor="#131C28"
                            Stroke="#1F2D3D"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18"
                            Padding="16">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Résumé participations"
                                   FontFamily="DMSans-SemiBold"
                                   FontSize="15"
                                   TextColor="#F2E8D5"/>

                            <Label Text="{Binding TotalMaybe, StringFormat='🤔 Peut-être : {0}'}"
                                   FontFamily="DMSans-Regular"
                                   FontSize="13"
                                   TextColor="#A8B3C3"/>

                            <Label Text="{Binding TotalDeclared, StringFormat='👥 Déclarations totales : {0}'}"
                                   FontFamily="DMSans-Regular"
                                   FontSize="13"
                                   TextColor="#A8B3C3"/>

                            <Label Text="{Binding FinishedEventsCount, StringFormat='✅ Événements terminés pris en compte : {0}'}"
                                   FontFamily="DMSans-Regular"
                                   FontSize="13"
                                   TextColor="#A8B3C3"/>

                            <Label Text="{Binding FinishedNoShow, StringFormat='👻 Absences estimées sur événements terminés : {0}'}"
                                   FontFamily="DMSans-Regular"
                                   FontSize="13"
                                   TextColor="#A8B3C3"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border BackgroundColor="#131C28"
                            Stroke="#1F2D3D"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18"
                            Padding="16">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Audience"
                                   FontFamily="DMSans-SemiBold"
                                   FontSize="15"
                                   TextColor="#F2E8D5"/>

                            <Label Text="Statistiques agrégées sur les participants annoncés. Les données sont masquées si l’échantillon est trop petit."
                                   FontFamily="DMSans-Regular"
                                   FontSize="12"
                                   TextColor="#A8B3C3"
                                   LineBreakMode="WordWrap"/>

                            <Label Text="{Binding DemographicPrivacyLabel}"
                                   FontFamily="DMSans-Regular"
                                   FontSize="12"
                                   TextColor="#FFB627"
                                   LineBreakMode="WordWrap"/>

                            <Label Text="{Binding GenderDistributionLabel, StringFormat='Sexe : {0}'}"
                                   FontFamily="DMSans-Regular"
                                   FontSize="13"
                                   TextColor="#F2E8D5"
                                   LineBreakMode="WordWrap"/>

                            <Label Text="{Binding AgeDistributionLabel, StringFormat='Âge : {0}'}"
                                   FontFamily="DMSans-Regular"
                                   FontSize="13"
                                   TextColor="#F2E8D5"
                                   LineBreakMode="WordWrap"/>

                            <Label Text="{Binding DominantAgeGroupLabel}"
                                   FontFamily="DMSans-Regular"
                                   FontSize="13"
                                   TextColor="#A8B3C3"
                                   LineBreakMode="WordWrap"/>

                            <Label Text="{Binding RelationshipDistributionLabel, StringFormat='Situation : {0}'}"
                                   FontFamily="DMSans-Regular"
                                   FontSize="13"
                                   TextColor="#F2E8D5"
                                   LineBreakMode="WordWrap"/>

                            <BoxView HeightRequest="1"
                                     BackgroundColor="#1F2D3D"
                                     Margin="0,4"/>

                            <Label Text="{Binding DemographicCheckedInTotal, StringFormat='Présences GPS confirmées : {0}'}"
                                   FontFamily="DMSans-SemiBold"
                                   FontSize="13"
                                   TextColor="#F2E8D5"/>

                            <Label Text="{Binding CheckedInGenderDistributionLabel, StringFormat='Sexe des présents : {0}'}"
                                   FontFamily="DMSans-Regular"
                                   FontSize="13"
                                   TextColor="#A8B3C3"
                                   LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="Détail par événement"
                           FontFamily="DMSans-SemiBold"
                           FontSize="15"
                           TextColor="#3D5068"
                           Margin="0,8,0,0"/>

                    <Label Text="Aucun événement pour le moment."
                           FontFamily="DMSans-Regular"
                           FontSize="13"
                           TextColor="#A8B3C3"
                           HorizontalOptions="Center"
                           Margin="0,20,0,0"
                           IsVisible="{Binding HasNoEvents}"/>

                    <CollectionView ItemsSource="{Binding Events}"
                                    IsVisible="{Binding HasEvents}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:OfficialEvent">
                                <Border BackgroundColor="#131C28"
                                        Stroke="#1F2D3D"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 18"
                                        Padding="14"
                                        Margin="0,8,0,0">
                                    <Grid ColumnDefinitions="72,*" ColumnSpacing="12">
                                        <Image Grid.Column="0"
                                               Source="{Binding FlyerUrl}"
                                               Aspect="AspectFill"
                                               WidthRequest="72"
                                               HeightRequest="72"/>

                                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                                            <Label Text="{Binding Title}"
                                                   FontFamily="DMSans-SemiBold"
                                                   FontSize="15"
                                                   TextColor="#F2E8D5"/>

                                            <Label Text="{Binding DateLabel}"
                                                   FontFamily="DMSans-Regular"
                                                   FontSize="12"
                                                   TextColor="#FFB627"/>

                                            <Label Text="{Binding GoingCount, StringFormat='🎉 {0} j’y vais'}"
                                                   FontFamily="DMSans-Regular"
                                                   FontSize="12"
                                                   TextColor="#A8B3C3"/>

                                            <Label Text="{Binding CheckedInCount, StringFormat='📍 {0} check-in GPS'}"
                                                   FontFamily="DMSans-Regular"
                                                   FontSize="12"
                                                   TextColor="#A8B3C3"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>
