<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NightOut.Views.Pro.ProOfficialEventsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:NightOut.ViewModels"
    xmlns:models="clr-namespace:NightOut.Models"
    x:DataType="vm:ProOfficialEventsViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{DynamicResource BgDeep}">

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" BackgroundColor="{DynamicResource BgCard}" Padding="20,50,20,22" ColumnDefinitions="Auto,*" ColumnSpacing="14">
            <Border Grid.Column="0" BackgroundColor="{DynamicResource BgElevated}" StrokeThickness="0" StrokeShape="RoundRectangle 22" WidthRequest="44" HeightRequest="44">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding BackCommand}"/>
                </Border.GestureRecognizers>
                <Label Text="‹" FontSize="28" TextColor="{DynamicResource Accent}" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                <Label Text="Événements officiels" FontFamily="DMSans-SemiBold" FontSize="22" TextColor="{DynamicResource TextPrimary}"/>
                <Label Text="Création compatible multi-établissements" FontFamily="DMSans-Regular" FontSize="13" TextColor="{DynamicResource TextMuted}"/>
            </VerticalStackLayout>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,12,20,30" Spacing="12">

                <Border BackgroundColor="{DynamicResource BgPanel}" Stroke="{DynamicResource Error}" StrokeThickness="1" StrokeShape="RoundRectangle 18" Padding="16" IsVisible="{Binding CannotCreateEvents}">
                    <Label Text="Ton compte professionnel doit être validé par Spotiz avant de créer des événements officiels." FontFamily="DMSans-Regular" FontSize="13" TextColor="{DynamicResource TextPrimary}"/>
                </Border>

                <Label Text="ÉTABLISSEMENT CONCERNÉ" FontFamily="DMSans-SemiBold" FontSize="13" TextColor="{DynamicResource TextMuted}" Margin="0,10,0,0"/>

                <Border BackgroundColor="{DynamicResource BgElevated}" Stroke="{DynamicResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="12,4">
                    <Picker ItemsSource="{Binding MyBars}"
                            SelectedItem="{Binding SelectedBar}"
                            ItemDisplayBinding="{Binding Name}"
                            Title="Choisir l'établissement"
                            TextColor="{DynamicResource TextPrimary}"
                            TitleColor="{DynamicResource TextSecondary}"/>
                </Border>

                <Label Text="{Binding SelectedBarLabel}" FontFamily="DMSans-Regular" FontSize="12" TextColor="{DynamicResource Accent}"/>

                <Label Text="NOUVEL ÉVÉNEMENT" FontFamily="DMSans-SemiBold" FontSize="13" TextColor="{DynamicResource TextMuted}" Margin="0,12,0,0"/>

                <Border BackgroundColor="{DynamicResource BgElevated}" Stroke="{DynamicResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="14,2">
                    <Entry Text="{Binding EventTitle}" Placeholder="Titre de l'événement" TextColor="{DynamicResource TextPrimary}" PlaceholderColor="{DynamicResource TextMuted}" BackgroundColor="Transparent"/>
                </Border>

                <Border BackgroundColor="{DynamicResource BgElevated}" Stroke="{DynamicResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="14,10">
                    <Editor Text="{Binding Description}" Placeholder="Description, ambiance, DJ, thème..." PlaceholderColor="{DynamicResource TextMuted}" TextColor="{DynamicResource TextPrimary}" BackgroundColor="Transparent" AutoSize="TextChanges" MinimumHeightRequest="90"/>
                </Border>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Border Grid.Column="0" BackgroundColor="{DynamicResource BgElevated}" Stroke="{DynamicResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="8,4">
                        <DatePicker Date="{Binding EventDate}" TextColor="{DynamicResource TextPrimary}"/>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="{DynamicResource BgElevated}" Stroke="{DynamicResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="8,4">
                        <TimePicker Time="{Binding StartTime}" TextColor="{DynamicResource TextPrimary}"/>
                    </Border>
                    <Border Grid.Column="2" BackgroundColor="{DynamicResource BgElevated}" Stroke="{DynamicResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="8,4">
                        <TimePicker Time="{Binding EndTime}" TextColor="{DynamicResource TextPrimary}"/>
                    </Border>
                </Grid>

                <Border BackgroundColor="{DynamicResource BgElevated}" Stroke="{DynamicResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="14,2">
                    <Entry Text="{Binding MaxParticipants}" Keyboard="Numeric" Placeholder="Nombre max de participants, optionnel" TextColor="{DynamicResource TextPrimary}" PlaceholderColor="{DynamicResource TextMuted}" BackgroundColor="Transparent"/>
                </Border>

                <Border BackgroundColor="{DynamicResource BgElevated}" Stroke="{DynamicResource Accent}" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PickFlyerCommand}"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="🖼️" FontSize="22" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Ajouter un flyer" FontFamily="DMSans-SemiBold" FontSize="15" TextColor="{DynamicResource TextPrimary}"/>
                            <Label Text="Le flyer sera rattaché à l'établissement sélectionné" FontFamily="DMSans-Regular" FontSize="12" TextColor="{DynamicResource TextSecondary}"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Image Source="{Binding FlyerUrl}" Aspect="AspectFill" HeightRequest="180" IsVisible="{Binding HasFlyer}"/>

                <Button Text="Créer l'événement officiel" Command="{Binding CreateEventCommand}" BackgroundColor="{DynamicResource Accent}" TextColor="{DynamicResource BgDeep}" FontFamily="DMSans-SemiBold" CornerRadius="18" HeightRequest="54"/>

                <Label Text="STATISTIQUES DE L'ÉTABLISSEMENT SÉLECTIONNÉ" FontFamily="DMSans-SemiBold" FontSize="13" TextColor="{DynamicResource TextMuted}" Margin="0,16,0,0"/>

                <Border BackgroundColor="{DynamicResource BgElevated}" Stroke="{DynamicResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 20" Padding="16" IsVisible="{Binding HasEvents}">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                        <Label Grid.Row="0" Grid.Column="0" Text="{Binding TotalEvents, StringFormat='🎉 {0} événements'}" TextColor="{DynamicResource TextPrimary}" FontSize="15"/>
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding TotalGoing, StringFormat='✅ {0} j’y vais'}" TextColor="{DynamicResource TextPrimary}" FontSize="15"/>
                        <Label Grid.Row="1" Grid.Column="0" Text="{Binding TotalCheckedIn, StringFormat='📍 {0} check-in'}" TextColor="{DynamicResource TextPrimary}" FontSize="15"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding AverageReliabilityLabel, StringFormat='Fiabilité {0}'}" TextColor="{DynamicResource Accent}" FontSize="15"/>
                    </Grid>
                </Border>

                <Label Text="Aucun événement pour cet établissement." TextColor="{DynamicResource TextSecondary}" FontSize="13" IsVisible="{Binding HasNoEvents}"/>

                <CollectionView ItemsSource="{Binding Events}" Margin="0,8,0,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:OfficialEvent">
                            <Border BackgroundColor="{DynamicResource BgElevated}" Stroke="{DynamicResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="12" Margin="0,6">
                                <Grid ColumnDefinitions="72,*" ColumnSpacing="12">
                                    <Image Grid.Column="0" Source="{Binding FlyerUrl}" Aspect="AspectFill" WidthRequest="72" HeightRequest="72"/>
                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <Label Text="{Binding Title}" FontFamily="DMSans-SemiBold" FontSize="15" TextColor="{DynamicResource TextPrimary}"/>
                                        <Label Text="{Binding BarDisplay}" FontFamily="DMSans-Regular" FontSize="12" TextColor="{DynamicResource Accent}"/>
                                        <Label Text="{Binding DateLabel}" FontFamily="DMSans-Regular" FontSize="12" TextColor="{DynamicResource TextSecondary}"/>
                                        <Label Text="{Binding ParticipantsStatsLabel}" FontFamily="DMSans-Regular" FontSize="12" TextColor="{DynamicResource TextSecondary}"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
