<?xml version="1.0" encoding="utf-8" ?>
<Application
    x:Class="NightOut.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <Application.Resources>
        <ResourceDictionary>

            <!--
                Le dictionnaire de couleurs (ColorsLight ou ColorsDark) est ajouté
                dynamiquement au démarrage par ThemeService.Initialize(), appelé
                depuis App.xaml.cs juste après InitializeComponent().
                Ne pas ajouter de <Color x:Key="..."> ici : tout passe par
                Resources/Styles/Colors.Light.xaml et Colors.Dark.xaml.
            -->

            <!-- ══ CONVERTERS ══ -->
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
            <toolkit:BoolToObjectConverter x:Key="BoolToSecretBgConverter"
                                           TrueObject="{DynamicResource SecretOverlayOn}"
                                           FalseObject="{DynamicResource SecretOverlayOff}"/>

            <!-- ══ STYLES GLOBAUX ══ -->
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="FontFamily" Value="DMSans-Regular"/>
            </Style>

            <Style TargetType="Entry">
                <Setter Property="TextColor" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="PlaceholderColor" Value="{DynamicResource TextMuted}"/>
                <Setter Property="FontFamily" Value="DMSans-Regular"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="BackgroundColor" Value="Transparent"/>
            </Style>

            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{DynamicResource BgDeep}"/>
            </Style>

            <Style x:Key="BtnPrimary" TargetType="Border">
                <Setter Property="StrokeShape" Value="RoundRectangle 14"/>
                <Setter Property="StrokeThickness" Value="0"/>
                <Setter Property="HeightRequest" Value="50"/>
            </Style>

            <Style x:Key="BtnSecondary" TargetType="Border">
                <Setter Property="StrokeShape" Value="RoundRectangle 14"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="Stroke" Value="{DynamicResource BorderMid}"/>
                <Setter Property="BackgroundColor" Value="{DynamicResource AccentDim}"/>
                <Setter Property="HeightRequest" Value="50"/>
            </Style>

            <Style x:Key="InputField" TargetType="Border">
                <Setter Property="StrokeShape" Value="RoundRectangle 12"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="Stroke" Value="{DynamicResource Border}"/>
                <Setter Property="BackgroundColor" Value="{DynamicResource BgElevated}"/>
                <Setter Property="HeightRequest" Value="50"/>
                <Setter Property="Padding" Value="14,0"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>

</Application>
