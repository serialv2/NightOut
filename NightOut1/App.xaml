<?xml version="1.0" encoding="utf-8" ?>
<Application
    x:Class="NightOut.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <Application.Resources>
        <ResourceDictionary>

            <!-- ══ CONVERTERS ══ -->
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
            <toolkit:BoolToObjectConverter x:Key="BoolToSecretBgConverter"
                                           TrueObject="#2E7B5DE5"
                                           FalseObject="#CC0A1018"/>

            <!-- ══ COULEURS GLOBALES ══ -->
            <Color x:Key="BgDeep">#0A1018</Color>
            <Color x:Key="BgCard">#0F1923</Color>
            <Color x:Key="BgPanel">#131F2B</Color>
            <Color x:Key="BgElevated">#1A2535</Color>
            <Color x:Key="Accent">#FFB627</Color>
            <Color x:Key="AccentDim">#1AFFB627</Color>
            <Color x:Key="AccentSoft">#2EFFB627</Color>
            <Color x:Key="Second">#FF6B35</Color>
            <Color x:Key="TextPrimary">#F2E8D5</Color>
            <Color x:Key="TextSecondary">#7A8FA6</Color>
            <Color x:Key="TextMuted">#3D5068</Color>
            <Color x:Key="Border">#1AFFB627</Color>
            <Color x:Key="BorderMid">#2EFFB627</Color>
            <Color x:Key="GaugeLow">#3DB87A</Color>
            <Color x:Key="GaugeMid">#FFB627</Color>
            <Color x:Key="GaugeHot">#FF6B35</Color>
            <Color x:Key="GaugeFire">#FF2D6B</Color>
            <Color x:Key="Success">#3DB87A</Color>
            <Color x:Key="Error">#E53935</Color>

            <!-- ══ STYLES GLOBAUX ══ -->
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
                <Setter Property="FontFamily" Value="DMSans-Regular"/>
            </Style>

            <Style TargetType="Entry">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
                <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}"/>
                <Setter Property="FontFamily" Value="DMSans-Regular"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="BackgroundColor" Value="Transparent"/>
            </Style>

            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{StaticResource BgDeep}"/>
            </Style>

            <Style x:Key="BtnPrimary" TargetType="Border">
                <Setter Property="StrokeShape" Value="RoundRectangle 14"/>
                <Setter Property="StrokeThickness" Value="0"/>
                <Setter Property="HeightRequest" Value="50"/>
            </Style>

            <Style x:Key="BtnSecondary" TargetType="Border">
                <Setter Property="StrokeShape" Value="RoundRectangle 14"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="Stroke" Value="{StaticResource BorderMid}"/>
                <Setter Property="BackgroundColor" Value="{StaticResource AccentDim}"/>
                <Setter Property="HeightRequest" Value="50"/>
            </Style>

            <Style x:Key="InputField" TargetType="Border">
                <Setter Property="StrokeShape" Value="RoundRectangle 12"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="Stroke" Value="{StaticResource Border}"/>
                <Setter Property="BackgroundColor" Value="{StaticResource BgElevated}"/>
                <Setter Property="HeightRequest" Value="50"/>
                <Setter Property="Padding" Value="14,0"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>

</Application>
