<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NightOut.Views.Pro.RewardQrScannerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#0A1018">

    <Grid>
        <zxing:CameraBarcodeReaderView
            x:Name="BarcodeReader"
            BarcodesDetected="OnBarcodesDetected"
            IsDetecting="False" />

        <BoxView BackgroundColor="#660A1018"/>

        <Grid RowDefinitions="Auto,*,Auto" Padding="20,50,20,30">
            <Grid Grid.Row="0" ColumnDefinitions="44,*" ColumnSpacing="12">
                <Border Grid.Column="0"
                        BackgroundColor="#1A2535"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 14"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCloseTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="←"
                           FontSize="20"
                           TextColor="#F2E8D5"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Text="Scanner une récompense"
                           FontFamily="DMSans-SemiBold"
                           FontSize="20"
                           TextColor="#F2E8D5"/>
                    <Label Text="Place le QR code du client dans le cadre."
                           FontSize="12"
                           TextColor="#A8B3C3"/>
                </VerticalStackLayout>
            </Grid>

            <Border Grid.Row="1"
                    WidthRequest="260"
                    HeightRequest="260"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    BackgroundColor="#22000000"
                    Stroke="#FFB627"
                    StrokeThickness="3"
                    StrokeShape="RoundRectangle 28">
                <Grid>
                    <Label Text="QR"
                           FontFamily="DMSans-Bold"
                           FontSize="34"
                           TextColor="#55F2E8D5"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    BackgroundColor="#131C28"
                    Stroke="#1F2D3D"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 18"
                    Padding="14">
                <Label Text="Le débit des points se fait seulement après validation serveur."
                       FontSize="12"
                       TextColor="#A8B3C3"
                       HorizontalTextAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
